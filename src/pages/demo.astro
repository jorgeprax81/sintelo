---
import Layout from '../layouts/Layout.astro';
import pg from 'pg';
const { Pool } = pg;

export const prerender = false;

const pool = new Pool({
  connectionString: import.meta.env.DATABASE_URL,
  ssl: { rejectUnauthorized: false }
});

// Fetch all KPIs in parallel
const [
  revenueRes,
  margenRes,
  diasRes,
  paretoRes,
  yoyRes,
  mixRes,
  top5Res,
  territorioRes,
] = await Promise.all([
  pool.query(`
    SELECT ROUND(SUM(totaldue)::numeric, 2) AS revenue_total
    FROM sales.salesorderheader WHERE status = 5
  `),
  pool.query(`
    SELECT ROUND(
      (SUM(soh.totaldue) - SUM(detalle.cogs)) / SUM(soh.totaldue) * 100, 1
    ) AS margen_bruto_pct
    FROM sales.salesorderheader soh
    JOIN (
      SELECT salesorderid, SUM(orderqty * c.standardcost) AS cogs
      FROM sales.salesorderdetail sod
      JOIN (
        SELECT DISTINCT ON (productid) productid, standardcost
        FROM production.productcosthistory
        ORDER BY productid, startdate DESC
      ) c ON sod.productid = c.productid
      GROUP BY salesorderid
    ) detalle ON soh.salesorderid = detalle.salesorderid
    WHERE soh.status = 5
  `),
  pool.query(`
    SELECT ROUND(
      SUM(pi.quantity * c.standardcost) / (SUM(cogs.cogs_anual) / 365), 0
    ) AS dias
    FROM production.productinventory pi
    JOIN production.product p ON pi.productid = p.productid
    JOIN production.productsubcategory ps ON p.productsubcategoryid = ps.productsubcategoryid
    JOIN production.productcategory pc ON ps.productcategoryid = pc.productcategoryid
    JOIN (
      SELECT DISTINCT ON (productid) productid, standardcost
      FROM production.productcosthistory ORDER BY productid, startdate DESC
    ) c ON pi.productid = c.productid
    JOIN (
      SELECT d.productid, SUM(d.orderqty * c2.standardcost) AS cogs_anual
      FROM sales.salesorderdetail d
      JOIN sales.salesorderheader soh ON d.salesorderid = soh.salesorderid
      JOIN (
        SELECT DISTINCT ON (productid) productid, standardcost
        FROM production.productcosthistory ORDER BY productid, startdate DESC
      ) c2 ON d.productid = c2.productid
      WHERE soh.status = 5 AND EXTRACT(YEAR FROM soh.orderdate) = 2024
      GROUP BY d.productid
    ) cogs ON pi.productid = cogs.productid
    WHERE pc.name = 'Components'
  `),
  pool.query(`
    WITH revenue_por_sku AS (
      SELECT p.productid,
        SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount)) AS revenue
      FROM sales.salesorderdetail sod
      JOIN sales.salesorderheader soh ON sod.salesorderid = soh.salesorderid
      JOIN production.product p ON sod.productid = p.productid
      WHERE soh.status = 5
      GROUP BY p.productid
    ), acumulado AS (
      SELECT revenue,
        SUM(revenue) OVER (ORDER BY revenue DESC) / SUM(revenue) OVER () * 100 AS pct_acumulado
      FROM revenue_por_sku
    )
    SELECT ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM revenue_por_sku), 1) AS pct_skus
    FROM acumulado WHERE pct_acumulado <= 80
  `),
  pool.query(`
    SELECT EXTRACT(YEAR FROM orderdate)::int AS año,
      ROUND(SUM(totaldue)::numeric, 2) AS revenue
    FROM sales.salesorderheader WHERE status = 5
    GROUP BY año ORDER BY año
  `),
  pool.query(`
    SELECT pc.name AS categoria,
      ROUND(SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount))::numeric, 2) AS revenue,
      ROUND(SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount)) /
        SUM(SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount))) OVER () * 100, 1) AS pct
    FROM sales.salesorderheader soh
    JOIN sales.salesorderdetail sod ON soh.salesorderid = sod.salesorderid
    JOIN production.product p ON sod.productid = p.productid
    JOIN production.productsubcategory ps ON p.productsubcategoryid = ps.productsubcategoryid
    JOIN production.productcategory pc ON ps.productcategoryid = pc.productcategoryid
    WHERE soh.status = 5
    GROUP BY pc.name ORDER BY revenue DESC
  `),
  pool.query(`
    SELECT p.name AS producto,
      ROUND(SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount))::numeric, 2) AS revenue
    FROM sales.salesorderdetail sod
    JOIN sales.salesorderheader soh ON sod.salesorderid = soh.salesorderid
    JOIN production.product p ON sod.productid = p.productid
    WHERE soh.status = 5
    GROUP BY p.productid, p.name
    ORDER BY revenue DESC LIMIT 5
  `),
  pool.query(`
    SELECT st.name AS territorio,
      ROUND(SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount))::numeric, 2) AS revenue,
      ROUND(SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount)) /
        SUM(SUM(sod.orderqty * sod.unitprice * (1 - sod.unitpricediscount))) OVER () * 100, 1) AS pct
    FROM sales.salesorderheader soh
    JOIN sales.salesorderdetail sod ON sod.salesorderid = soh.salesorderid
    JOIN sales.salesterritory st ON soh.territoryid = st.territoryid
    WHERE soh.status = 5
    GROUP BY st.territoryid, st.name
    ORDER BY revenue DESC
  `),
]);

await pool.end();

const revenue = Number(revenueRes.rows[0].revenue_total);
const margen = Number(margenRes.rows[0].margen_bruto_pct);
const dias = Number(diasRes.rows[0].dias);
const pctSkus = Number(paretoRes.rows[0].pct_skus);
const yoy = yoyRes.rows;
const mix = mixRes.rows;
const top5 = top5Res.rows;
const territorios = territorioRes.rows;

function formatM(n: number) {
  return '$' + (n / 1_000_000).toFixed(1) + 'M';
}

function formatNum(n: number) {
  return n.toLocaleString('es-MX', { maximumFractionDigits: 0 });
}

// YoY growth latest
const yoyGrowth = yoy.length >= 2
  ? ((Number(yoy[yoy.length-2].revenue) - Number(yoy[yoy.length-3]?.revenue || 0)) / Number(yoy[yoy.length-3]?.revenue || 1) * 100).toFixed(1)
  : null;

const maxRevenue = Math.max(...yoy.map(r => Number(r.revenue)));
const maxTop5 = Math.max(...top5.map(r => Number(r.revenue)));
---

<Layout>

<!-- DEMO HERO -->
<section class="demo-hero">
  <div class="demo-eyebrow">Demo en vivo · Datos reales · AdventureWorks Inc.</div>
  <h1>Diagnóstico ROIC <em>en tiempo real</em></h1>
  <p class="demo-sub">
    Así es como Sintelo analiza su empresa. Los datos que ve a continuación son calculados en este momento desde nuestra base de datos — exactamente como lo haríamos con su información financiera.
  </p>
  <div class="demo-disclaimer">
    <span class="disc-dot"></span>
    Empresa de demostración: AdventureWorks Inc. — fabricante de bicicletas con operaciones en Norteamérica, Europa y Pacífico.
  </div>
</section>

<!-- KPIs -->
<section class="kpi-section">
  <div class="kpi-label">Indicadores clave</div>
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="kpi-val">{formatM(revenue)}</div>
      <div class="kpi-name">Revenue total</div>
      <div class="kpi-sub">Órdenes completadas</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-val">{margen}%</div>
      <div class="kpi-name">Margen bruto</div>
      <div class="kpi-sub">Proxy operativo</div>
    </div>
    <div class="kpi-card kpi-alert">
      <div class="kpi-val">{formatNum(dias)}</div>
      <div class="kpi-name">Días de inventario</div>
      <div class="kpi-sub">Components · Alerta crítica</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-val">{pctSkus}%</div>
      <div class="kpi-name">SKUs → 80% revenue</div>
      <div class="kpi-sub">Concentración Pareto</div>
    </div>
  </div>
</section>

<!-- RESUMEN EJECUTIVO -->
<section class="exec-section">
  <div class="exec-label">Resumen ejecutivo</div>
  <h2>Tres hallazgos. Dos palancas. Una dirección.</h2>

  <div class="hallazgos-grid">
    <div class="hallazgo hallazgo-1">
      <div class="h-num">01</div>
      <div class="h-lever">Lever: Complejidad de producto</div>
      <div class="h-title">El 86% del revenue viene de Bikes.</div>
      <p class="h-body">
        Una sola categoría genera casi todo el ingreso. Clothing y Accessories representan apenas el 3% combinado.
        Esta concentración crea fragilidad estructural — cualquier contracción en el mercado de bicicletas
        impacta directamente el ROIC total. La oportunidad: evaluar si Components y Clothing tienen potencial
        de escala, o si se deben simplificar para liberar capital operativo.
      </p>
      <div class="h-accion">→ Palanca A · Margen operativo</div>
    </div>

    <div class="hallazgo hallazgo-2">
      <div class="h-num">02</div>
      <div class="h-lever">Lever: Working Capital + Pricing</div>
      <div class="h-title">Components: {formatNum(dias)} días de inventario, vendido al 58% del precio lista.</div>
      <p class="h-body">
        El hallazgo más crítico de este diagnóstico. Components tiene más de 7 meses de inventario parado
        — capital inmovilizado que no genera retorno. Simultáneamente, se vende con un descuento efectivo
        del 42% sobre precio lista. La combinación destruye valor en ambas palancas: comprime el margen
        y eleva el capital invertido. Acción inmediata: programa de liquidación + revisión de política de precios.
      </p>
      <div class="h-accion">→ Palanca B · Rotación de capital</div>
    </div>

    <div class="hallazgo hallazgo-3">
      <div class="h-num">03</div>
      <div class="h-lever">Lever: Sales Enhancement</div>
      <div class="h-title">Southwest concentra el 22% del revenue. Germany, el 4.5%.</div>
      <p class="h-body">
        North America genera el 72% del revenue total. La dependencia geográfica replica la dependencia
        de producto: alta concentración, alta fragilidad. Europe representa el 18% con margen de crecimiento
        significativo — especialmente Germany y France, que tienen operaciones activas pero sub-penetradas
        relativo al tamaño del mercado.
      </p>
      <div class="h-accion">→ Palanca A · Revenue improvement</div>
    </div>
  </div>
</section>

<!-- PALANCA A -->
<section class="palanca-section">
  <div class="palanca-header">
    <div class="p-badge">Palanca A</div>
    <h2>Margen operativo</h2>
    <p class="p-sub">Revenue · Pricing · Costos · Mezcla de productos</p>
  </div>

  <div class="charts-grid">

    <!-- Revenue por año -->
    <div class="chart-card">
      <div class="chart-title">Revenue por año</div>
      <div class="chart-sub">Órdenes completadas (status = 5)</div>
      <div class="bar-chart">
        {yoy.map((row) => {
          const pct = (Number(row.revenue) / maxRevenue * 100).toFixed(1);
          const isPartial = Number(row.año) === Math.max(...yoy.map(r => Number(r.año)));
          return (
            <div class="bar-row">
              <div class="bar-año">{row.año}</div>
              <div class="bar-track">
                <div class="bar-fill" style={`width: ${pct}%`}></div>
              </div>
              <div class="bar-val">
                {formatM(Number(row.revenue))}
                {isPartial && <span class="bar-tag">parcial</span>}
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Mix por categoría -->
    <div class="chart-card">
      <div class="chart-title">Mix de revenue por categoría</div>
      <div class="chart-sub">Distribución de ventas netas</div>
      <div class="mix-list">
        {mix.map((row) => (
          <div class="mix-row">
            <div class="mix-name">{row.categoria}</div>
            <div class="mix-bar-wrap">
              <div class="mix-bar" style={`width: ${row.pct}%`}></div>
            </div>
            <div class="mix-pct">{row.pct}%</div>
          </div>
        ))}
      </div>
      <div class="mix-insight">
        Bikes genera el <strong>86%</strong> del revenue — concentración extrema.
      </div>
    </div>

    <!-- Top 5 SKUs -->
    <div class="chart-card chart-wide">
      <div class="chart-title">Top 5 SKUs por revenue</div>
      <div class="chart-sub">El 24% de los SKUs genera el 80% del revenue total</div>
      <div class="sku-list">
        {top5.map((row, i) => {
          const pct = (Number(row.revenue) / maxTop5 * 100).toFixed(1);
          return (
            <div class="sku-row">
              <div class="sku-rank">{String(i+1).padStart(2,'0')}</div>
              <div class="sku-info">
                <div class="sku-name">{row.producto}</div>
                <div class="sku-bar-wrap">
                  <div class="sku-bar" style={`width: ${pct}%`}></div>
                </div>
              </div>
              <div class="sku-val">{formatM(Number(row.revenue))}</div>
            </div>
          );
        })}
      </div>
    </div>

  </div>
</section>

<!-- PALANCA B -->
<section class="palanca-section palanca-b">
  <div class="palanca-header">
    <div class="p-badge p-badge-b">Palanca B</div>
    <h2>Rotación de capital</h2>
    <p class="p-sub">Working capital · Inventario · Capex</p>
  </div>

  <div class="charts-grid">

    <!-- Días de inventario -->
    <div class="chart-card">
      <div class="chart-title">Días de inventario por categoría</div>
      <div class="chart-sub">Basado en COGS 2024</div>
      <div class="inv-list">
        <div class="inv-row inv-critical">
          <div class="inv-cat">Components</div>
          <div class="inv-bar-wrap">
            <div class="inv-bar inv-bar-red" style="width: 100%"></div>
          </div>
          <div class="inv-dias">{formatNum(dias)} días</div>
          <div class="inv-badge">Crítico</div>
        </div>
        <div class="inv-row">
          <div class="inv-cat">Bikes</div>
          <div class="inv-bar-wrap">
            <div class="inv-bar" style="width: 23%"></div>
          </div>
          <div class="inv-dias">53 días</div>
          <div class="inv-badge inv-ok">Saludable</div>
        </div>
        <div class="inv-row">
          <div class="inv-cat">Clothing</div>
          <div class="inv-bar-wrap">
            <div class="inv-bar" style="width: 23%"></div>
          </div>
          <div class="inv-dias">52 días</div>
          <div class="inv-badge inv-ok">Saludable</div>
        </div>
        <div class="inv-row">
          <div class="inv-cat">Accessories</div>
          <div class="inv-bar-wrap">
            <div class="inv-bar" style="width: 30%"></div>
          </div>
          <div class="inv-dias">69 días</div>
          <div class="inv-badge inv-watch">Monitorear</div>
        </div>
      </div>
      <div class="inv-insight">
        Components tiene <strong>7+ meses</strong> de stock — capital inmovilizado sin retorno.
      </div>
    </div>

    <!-- Precio lista vs real -->
    <div class="chart-card">
      <div class="chart-title">Precio lista vs precio real</div>
      <div class="chart-sub">Descuento efectivo por categoría</div>
      <div class="precio-list">
        <div class="precio-row precio-critical">
          <div class="precio-cat">Components</div>
          <div class="precio-vals">
            <div class="precio-bar-wrap">
              <div class="precio-real" style="width: 58%">
                <span class="precio-label">Real 58%</span>
              </div>
              <div class="precio-gap" style="width: 42%">
                <span class="precio-label">-42%</span>
              </div>
            </div>
          </div>
        </div>
        <div class="precio-row">
          <div class="precio-cat">Clothing</div>
          <div class="precio-vals">
            <div class="precio-bar-wrap">
              <div class="precio-real" style="width: 74.2%">
                <span class="precio-label">Real 74%</span>
              </div>
              <div class="precio-gap" style="width: 25.8%">
                <span class="precio-label">-26%</span>
              </div>
            </div>
          </div>
        </div>
        <div class="precio-row">
          <div class="precio-cat">Bikes</div>
          <div class="precio-vals">
            <div class="precio-bar-wrap">
              <div class="precio-real" style="width: 75%">
                <span class="precio-label">Real 75%</span>
              </div>
              <div class="precio-gap" style="width: 25%">
                <span class="precio-label">-25%</span>
              </div>
            </div>
          </div>
        </div>
        <div class="precio-row">
          <div class="precio-cat">Accessories</div>
          <div class="precio-vals">
            <div class="precio-bar-wrap">
              <div class="precio-real precio-ok" style="width: 91.2%">
                <span class="precio-label">Real 91%</span>
              </div>
              <div class="precio-gap precio-gap-sm" style="width: 8.8%">
                <span class="precio-label">-9%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Territorios -->
    <div class="chart-card chart-wide">
      <div class="chart-title">Revenue por territorio</div>
      <div class="chart-sub">Distribución geográfica de ventas</div>
      <div class="territorio-grid">
        {territorios.map((row) => (
          <div class="t-row">
            <div class="t-name">{row.territorio}</div>
            <div class="t-bar-wrap">
              <div class="t-bar" style={`width: ${Number(row.pct)}%`}></div>
            </div>
            <div class="t-pct">{row.pct}%</div>
          </div>
        ))}
      </div>
      <div class="t-insight">
        North America concentra el <strong>72%</strong> — alta dependencia geográfica.
      </div>
    </div>

  </div>
</section>

<!-- BUSINESS CASE -->
<section class="bc-section">
  <div class="bc-label">Business case</div>
  <h2>¿Cuánto vale capturar estas oportunidades?</h2>
  <p class="bc-intro">
    Estimación conservadora del valor capturado si se ejecutan las tres iniciativas prioritarias.
    Basada en los datos de AdventureWorks — su empresa tendría cifras específicas a su realidad.
  </p>
  <div class="bc-grid">
    <div class="bc-item">
      <div class="bc-num">01</div>
      <div class="bc-title">Reducir inventario Components de 224 a 90 días</div>
      <div class="bc-val">~$2.4M liberados</div>
      <p class="bc-desc">Capital que hoy está parado en estantes puede convertirse en efectivo o reinvertirse en categorías con mayor rotación.</p>
    </div>
    <div class="bc-item">
      <div class="bc-num">02</div>
      <div class="bc-title">Recuperar 10pp del descuento efectivo en Components</div>
      <div class="bc-val">~$1.2M en margen adicional</div>
      <p class="bc-desc">Pasar de 58% a 68% del precio lista en una categoría de $12M en COGS representa un impacto directo en NOPAT.</p>
    </div>
    <div class="bc-item">
      <div class="bc-num">03</div>
      <div class="bc-title">Simplificar el 76% de SKUs de cola</div>
      <div class="bc-val">Overhead reducido + capital liberado</div>
      <p class="bc-desc">Los SKUs que no están en el Pareto consumen complejidad operativa, inventario y atención de ventas desproporcionados a su contribución.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="demo-cta">
  <div class="cta-inner">
    <div class="cta-tag">Este análisis tomó segundos. El suyo también.</div>
    <h2>¿Quiere ver el diagnóstico<br>de <em>su</em> empresa?</h2>
    <p class="cta-body">
      Conectamos sus datos financieros y operativos. En días — no semanas — tiene su ROIC real,
      sus levers prioritizados y un business case cuantificado.
    </p>
    <a href="/#contacto" class="btn-demo-cta">Solicitar diagnóstico →</a>
    <div class="cta-note">Precio fijo · sin contrato de implementación por adelantado</div>
  </div>
</section>

</Layout>

<style>
