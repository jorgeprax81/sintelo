---
import Layout from '../../layouts/Layout.astro';
import { getPool } from '../../lib/db';
import { buildValueBridge, calcLevers, type BalanceRow, type IncomeRow } from '../../lib/roic-engine';
export const prerender = false;

const pool = getPool('bigretailer');

const [isRes, bsRes, cfRes] = await Promise.all([
  pool.query(`SELECT * FROM clientes.income_statement WHERE empresa_id = 1 ORDER BY periodo`),
  pool.query(`SELECT * FROM clientes.balance_sheet WHERE empresa_id = 1 ORDER BY periodo`),
  pool.query(`SELECT * FROM clientes.cash_flow WHERE empresa_id = 1 ORDER BY periodo`),
]);

const is = isRes.rows;
const bs = bsRes.rows;
const cf = cfRes.rows;

const capexByPeriodo = new Map<string, number>(
  cf.map((row) => [String(row.periodo), Number(row.capex || 0)])
);

const incomeRows: IncomeRow[] = is.map((row) => ({
  periodo: String(row.periodo),
  revenue: row.revenue,
  sga: row.sga,
  ebit: row.ebit,
  impuestos: row.impuestos,
  ebt: row.ebt,
  capex: capexByPeriodo.get(String(row.periodo)) ?? 0
}));

const balanceRows: BalanceRow[] = bs.map((row) => ({
  periodo: String(row.periodo),
  ppe: row.ppe,
  cuentas_por_cobrar: row.cuentas_por_cobrar,
  inventario: row.inventario,
  cuentas_por_pagar: row.cuentas_por_pagar
}));

const preferredPeriod = 'Year 7';
const actualIncome = incomeRows.find((row) => row.periodo === preferredPeriod) ?? incomeRows[incomeRows.length - 1];
const actualBalanceRaw = balanceRows.find((row) => row.periodo === actualIncome.periodo) ?? balanceRows[balanceRows.length - 1];

const historicalInventories = balanceRows
  .filter((row) => row.periodo !== actualBalanceRaw.periodo)
  .map((row) => Number(row.inventario || 0));

const inventarioPromedioHistorico = historicalInventories.length > 0
  ? historicalInventories.reduce((sum, value) => sum + value, 0) / historicalInventories.length
  : Number(actualBalanceRaw.inventario || 0);

const actualBalance: BalanceRow = {
  ...actualBalanceRaw,
  inventario_promedio_historico: inventarioPromedioHistorico
};

const actualIndex = incomeRows.findIndex((row) => row.periodo === actualIncome.periodo);
const rowsForEngine = actualIndex >= 0 ? incomeRows.slice(0, actualIndex + 1) : incomeRows;
const leversEngine = calcLevers(rowsForEngine, actualBalance, cf);
const bridge = buildValueBridge(actualIncome, actualBalance, leversEngine);

const leverRoiPp = bridge.levers.map((lever) => lever.delta_pp);

const leverWidths = bridge.levers.map((lever) => {
  const maxImpact = Math.max(...bridge.levers.map((item) => item.impacto), 1);
  return `${Math.round((lever.impacto / maxImpact) * 100)}%`;
});

function fmt(n: number, parens = true) {
  if (n === 0) return '—';
  const abs = Math.abs(n).toLocaleString('en-US', { maximumFractionDigits: 0 });
  if (n < 0 && parens) return `(${abs})`;
  return abs;
}

const years = ['Year 1','Year 2','Year 3','Year 4','Year 5','Year 6','Year 7','Year 8'];
---

<Layout title="Sintelo — Big Retailer · Potential Report">

<section class="hero">
  <div class="eyebrow"><span class="dot"></span> Performance Improvement Potential · Big Retailer Inc.</div>
  <h1>De {bridge.roic_actual.toFixed(1)}% a {bridge.roic_potencial.toFixed(1)}% de ROIC.<br><em>${(bridge.total_valor / 1000).toFixed(1)}B USD de valor capturado en 3 años.</em></h1>
  <p class="sub">Diagnóstico basado en 8 periodos de estados financieros reales. Tres levers prioritarios con impacto cuantificado sobre NOPAT y capital invertido.</p>
  <div class="disclaimer"><span class="disc-dot"></span> Empresa de demostración: Big Retailer Inc. Cifras en USD millones.</div>
</section>

<!-- ROIC GAP -->
<section class="section">
  <div class="label">ROIC actual vs potencial</div>
  <div class="roic-gap">
    <div class="rg">
      <div class="rg-val cur">{bridge.roic_actual.toFixed(1)}%</div>
      <div class="rg-label">ROIC actual · {actualIncome.periodo}</div>
    </div>
    <div class="rg-arrow">→</div>
    <div class="rg">
      <div class="rg-val pot">{bridge.roic_potencial.toFixed(1)}%</div>
      <div class="rg-label">ROIC potencial · 3 años</div>
    </div>
  </div>
</section>

<!-- WATERFALL -->
<section class="section">
  <div class="label">Descomposición DuPont · cómo se construye el ROIC</div>
  <p class="section-body" style="margin-bottom:2rem">El ROIC se descompone en dos drivers que multiplicados dan el retorno total. Cada lever del diagnóstico mueve uno de los dos.</p>
  <div class="dupont-tree" style="margin-bottom:3rem">
    <div class="dupont-roic">
      <div class="dupont-label">ROIC actual</div>
      <div class="dupont-val">{bridge.roic_actual.toFixed(1)}%</div>
    </div>
    <div class="dupont-eq">=</div>
    <div class="dupont-driver">
      <div class="dupont-label">NOPAT margin</div>
      <div class="dupont-val">{bridge.nopat_margin.toFixed(1)}%</div>
      <div class="dupont-formula">NOPAT ÷ Revenue</div>
      <div class="dupont-palanca dupont-pa">Palanca A · Margen</div>
      <div class="dupont-items">SG&A · Pricing · Costos · Mezcla</div>
    </div>
    <div class="dupont-times">×</div>
    <div class="dupont-driver">
      <div class="dupont-label">Capital turnover</div>
      <div class="dupont-val">{bridge.capital_turnover.toFixed(2)}x</div>
      <div class="dupont-formula">Revenue ÷ Capital invertido</div>
      <div class="dupont-palanca dupont-pb">Palanca B · Capital</div>
      <div class="dupont-items">Working capital · Capex · Activos</div>
    </div>
  </div>
  <div class="label">Waterfall de valor · ROIC actual → ROIC potencial</div>
  <div style="position:relative;height:320px;margin-bottom:1rem;">
    <canvas id="wfChart" role="img" aria-label={`Waterfall ROIC de ${bridge.roic_actual.toFixed(1)}% a ${bridge.roic_potencial.toFixed(1)}% via tres levers`}>
      ROIC actual {bridge.roic_actual.toFixed(1)}%, {bridge.levers[0]?.nombre} +{leverRoiPp[0]?.toFixed(1)}pp, {bridge.levers[1]?.nombre} +{leverRoiPp[1]?.toFixed(1)}pp, {bridge.levers[2]?.nombre} +{leverRoiPp[2]?.toFixed(1)}pp, ROIC potencial {bridge.roic_potencial.toFixed(1)}%
    </canvas>
  </div>
  <div class="wf-legend">
    <span class="leg-item"><span class="leg-dot" style="background:#4A8FD4"></span>Punto de partida</span>
    <span class="leg-item"><span class="leg-dot" style="background:#4A9A7A"></span>Valor capturado por lever</span>
  </div>
</section>

<!-- LEVERS -->
<section class="section">
  <div class="label">Levers prioritarios · impacto cuantificado</div>
  <div class="levers">
    <div class="lever-header">
      <span>Lever</span>
      <span>Impacto relativo</span>
      <span>Valor capturado</span>
      <span>ROIC</span>
    </div>
    {bridge.levers.map((lever, index) => (
      <div class="lever">
        <div class="lname">{String(index + 1).padStart(2, '0')} · {lever.nombre}</div>
        <div class="lbar-wrap"><div class="lbar" style={`width:${leverWidths[index]};background:${lever.color}`}></div></div>
        <div class="lval">+${(lever.impacto / 1000).toFixed(1)}B USD{lever.frecuencia === 'anual' ? '/año' : ''}</div>
        <div class="lroic">+{leverRoiPp[index].toFixed(1)}pp</div>
      </div>
    ))}
  </div>
</section>

<!-- HEATMAP -->
<section class="section">
  <div class="label">Heatmap de priorización · impacto vs facilidad de captura</div>
  <p class="section-body" style="margin-bottom:2rem">No todos los levers se ejecutan igual. Esta matriz prioriza por dos dimensiones: cuánto mueve el ROIC y qué tan rápido se captura. Las burbujas en la esquina superior izquierda son las primeras olas de implementación; las de la derecha requieren transformación organizacional más larga.</p>
  <div style="position:relative;height:380px;margin-bottom:1rem;">
    <canvas id="hmChart" role="img" aria-label="Heatmap de priorización de levers por impacto en ROIC y tiempo de captura"></canvas>
  </div>
  <div class="hm-legend">
    <span class="leg-item"><span class="leg-dot" style="background:#7F77DD"></span>Palanca A · Margen</span>
    <span class="leg-item"><span class="leg-dot" style="background:#85B7EB"></span>Palanca B · Capital</span>
    <span class="leg-item" style="margin-left:1.5rem;color:var(--dim);font-style:italic">Tamaño de burbuja = facilidad de ejecución</span>
  </div>
</section>

<!-- ANÁLISIS POR LEVER -->
<section class="section">
  <div class="label">Análisis por lever</div>

  <div class="lever-detail">
    <div class="ld-header">
      <div class="ld-tag">Lever 01 — Palanca A · SG&A / Overhead</div>
      <div class="ld-title">SG&A creció 25% en 8 años. Revenue creció 15%.</div>
    </div>
    <div class="ld-cols">
      <div class="ld-col">
        <div class="ld-col-label">Situación actual</div>
        <p>SG&A: $116B (20.8% revenue)<br>EBITDA margin: 6.0%<br>vs 7.4% en Year 1</p>
      </div>
      <div class="ld-col">
        <div class="ld-col-label">Benchmark</div>
        <p>Retail eficiente: 18-19% SG&A<br>EBITDA objetivo: 8-9%<br>Gap: ~2pp de margen</p>
      </div>
      <div class="ld-col">
        <div class="ld-col-label">Iniciativa</div>
        <p>Auditoría de overhead por función<br>Target: -2pp SG&A en 18 meses<br>Valor: +${(bridge.levers[0].impacto / 1000).toFixed(1)}B de NOPAT</p>
      </div>
    </div>
  </div>

  <div class="lever-detail">
    <div class="ld-header">
      <div class="ld-tag">Lever 02 — Palanca B · Capex / Capital invertido</div>
      <div class="ld-title">$126B en capex en 4 años. ROIC cayó en ese mismo periodo.</div>
    </div>
    <div class="ld-cols">
      <div class="ld-col">
        <div class="ld-col-label">Situación actual</div>
        <p>Capex promedio: $32B/año<br>Sin criterio de ROIC mínimo<br>LTD creció $27B en 4 años</p>
      </div>
      <div class="ld-col">
        <div class="ld-col-label">Benchmark</div>
        <p>Retail eficiente: 3-4% revenue<br>ROIC mínimo requerido: 12%<br>Hurdle rate estándar industria</p>
      </div>
      <div class="ld-col">
        <div class="ld-col-label">Iniciativa</div>
        <p>Definir hurdle rate de 12% ROIC<br>Freeze capex no comprometido<br>Valor: +${(bridge.levers[1].impacto / 1000).toFixed(1)}B liberados/año</p>
      </div>
    </div>
  </div>

  <div class="lever-detail">
    <div class="ld-header">
      <div class="ld-tag">Lever 03 — Palanca B · Working capital / Inventario</div>
      <div class="ld-title">Inventario saltó $20B en Year 7 sin crecimiento de revenue proporcional.</div>
    </div>
    <div class="ld-cols">
      <div class="ld-col">
        <div class="ld-col-label">Situación actual</div>
        <p>Inventario Year 7: $65B<br>Histórico Years 1-6: $45-48B<br>Días inventario: ~58 días</p>
      </div>
      <div class="ld-col">
        <div class="ld-col-label">Benchmark</div>
        <p>Días inventario objetivo: 35-40<br>Nivel histórico propio: $46B<br>Gap: $17-20B de capital</p>
      </div>
      <div class="ld-col">
        <div class="ld-col-label">Iniciativa</div>
        <p>Programa de liquidación selectiva<br>Target: $48B en 12 meses<br>Valor: +${(bridge.levers[2].impacto / 1000).toFixed(1)}B de capital liberado</p>
      </div>
    </div>
  </div>
</section>

<!-- ROADMAP -->
<section class="section">
  <div class="label">Hoja de ruta · 18 meses</div>
  <div class="roadmap">
    <div class="rm">
      <div class="rm-phase">Fase 1 · 0-90 días</div>
      <div class="rm-title">Quick wins</div>
      <ul class="rm-items">
        <li>Auditoría de SG&A por función</li>
        <li>Freeze de capex no comprometido</li>
        <li>Diagnóstico de inventario Year 7</li>
        <li>Definir ROIC mínimo requerido (12%)</li>
        <li>Dashboard mensual de ROIC</li>
      </ul>
    </div>
    <div class="rm">
      <div class="rm-phase">Fase 2 · 90-365 días</div>
      <div class="rm-title">Transformación operativa</div>
      <ul class="rm-items">
        <li>Reducción estructural de overhead</li>
        <li>Programa de liquidación de inventario</li>
        <li>Nuevo proceso de aprobación de capex</li>
        <li>Renegociación de deuda LP</li>
        <li>Tracking mensual de iniciativas</li>
      </ul>
    </div>
    <div class="rm">
      <div class="rm-phase">Fase 3 · 12-18 meses</div>
      <div class="rm-title">Consolidación</div>
      <ul class="rm-items">
        <li>Verificar ROIC ≥ 13% sostenido</li>
        <li>Capacidades internas instaladas</li>
        <li>Modelo de capex con hurdle rate</li>
        <li>Informe final de valor creado</li>
        <li>Plan de mejora continua</li>
      </ul>
    </div>
  </div>
</section>

<!-- BUSINESS CASE -->
<section class="section">
  <div class="label">Business case total</div>
  <div class="bc-grid">
    <div class="bc">
      <div class="bc-val">${(bridge.total_valor / 1000).toFixed(1)}B USD</div>
      <div class="bc-label">Valor total capturado</div>
      <div class="bc-sub">En 3 años de implementación</div>
    </div>
    <div class="bc">
      <div class="bc-val">{bridge.roic_potencial.toFixed(1)}%</div>
      <div class="bc-label">ROIC potencial</div>
      <div class="bc-sub">vs {bridge.roic_actual.toFixed(1)}% actual</div>
    </div>
    <div class="bc">
      <div class="bc-val">+{bridge.delta_pp.toFixed(1)}pp</div>
      <div class="bc-label">Mejora de ROIC</div>
      <div class="bc-sub">En 3 años</div>
    </div>
  </div>
</section>

<!-- ESTADOS FINANCIEROS -->
<section class="section">
  <div class="label">Estados financieros · Big Retailer Inc.</div>
  <p class="fin-sub">Cifras en USD millones. Base del análisis anterior.</p>

  <section class="fs-section">
    <div class="fs-label">Income Statement</div>
    <div class="fs-sub">All figures in USD millions unless stated</div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="row-label"></th>
            {years.map(y => <th>{y}</th>)}
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="row-label">Revenue</td>
            {is.map(r => <td>{fmt(Number(r.revenue), false)}</td>)}
          </tr>
          <tr>
            <td class="row-label">COGS</td>
            {is.map(r => <td>{fmt(Number(r.cogs))}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">Gross Profit</td>
            {is.map(r => <td>{fmt(Number(r.gross_profit), false)}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr>
            <td class="row-label">SG&A</td>
            {is.map(r => <td>{fmt(Number(r.sga))}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">EBITDA</td>
            {is.map(r => <td>{fmt(Number(r.ebitda), false)}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr>
            <td class="row-label">Depreciation</td>
            {is.map(r => <td>{fmt(Number(r.depreciacion))}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">EBIT</td>
            {is.map(r => <td>{fmt(Number(r.ebit), false)}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr>
            <td class="row-label">Interest Expense</td>
            {is.map(r => <td>{fmt(Number(r.interes_gasto))}</td>)}
          </tr>
          <tr>
            <td class="row-label">Interest Income</td>
            {is.map(r => <td>{fmt(Number(r.interes_ingreso), false)}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">EBT</td>
            {is.map(r => <td>{fmt(Number(r.ebt), false)}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr>
            <td class="row-label">Provision for Taxes</td>
            {is.map(r => <td>{fmt(Number(r.impuestos))}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr class="total">
            <td class="row-label">Net Income</td>
            {is.map(r => <td>{fmt(Number(r.net_income), false)}</td>)}
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="fs-section">
    <div class="fs-label">Cash Flow Statement</div>
    <div class="fs-sub">All figures in USD millions unless stated</div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="row-label"></th>
            {years.map(y => <th>{y}</th>)}
          </tr>
        </thead>
        <tbody>
          <tr class="section-header"><td colspan="9">Cash from Operating</td></tr>
          <tr>
            <td class="row-label">Net Income</td>
            {cf.map(r => <td>{fmt(Number(r.net_income), false)}</td>)}
          </tr>
          <tr>
            <td class="row-label">Depreciation</td>
            {cf.map(r => <td>{fmt(Number(r.depreciacion), false)}</td>)}
          </tr>
          <tr>
            <td class="row-label">Cash From Accounts Receivable</td>
            {cf.map(r => <td>{fmt(Number(r.cambio_cxc))}</td>)}
          </tr>
          <tr>
            <td class="row-label">Cash From Inventory</td>
            {cf.map(r => <td>{fmt(Number(r.cambio_inventario))}</td>)}
          </tr>
          <tr>
            <td class="row-label">Cash From Accounts Payable</td>
            {cf.map(r => <td>{fmt(Number(r.cambio_cxp))}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">Subtotal</td>
            {cf.map(r => <td>{fmt(Number(r.flujo_operativo), false)}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr class="section-header"><td colspan="9">Cash from Investing</td></tr>
          <tr>
            <td class="row-label">Capital Expenditure</td>
            {cf.map(r => <td>{fmt(Number(r.capex))}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">Subtotal</td>
            {cf.map(r => <td>{fmt(Number(r.flujo_inversion))}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr class="section-header"><td colspan="9">Cash from Financing</td></tr>
          <tr>
            <td class="row-label">Change in Long-Term Debt</td>
            {cf.map(r => <td>{fmt(Number(r.cambio_deuda_lp))}</td>)}
          </tr>
          <tr>
            <td class="row-label">Change in Common Equity</td>
            {cf.map(r => <td>{fmt(Number(r.cambio_equity))}</td>)}
          </tr>
          <tr>
            <td class="row-label">Dividends</td>
            {cf.map(r => <td>—</td>)}
          </tr>
          <tr>
            <td class="row-label">Change in Revolving Credit Line</td>
            {cf.map(r => <td>{fmt(Number(r.cambio_credito_revolvente))}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">Subtotal</td>
            {cf.map(r => <td>{fmt(Number(r.flujo_financiamiento))}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr class="section-header"><td colspan="9">Cash Balance</td></tr>
          <tr>
            <td class="row-label">Beginning of the Year</td>
            {cf.map(r => <td>{fmt(Number(r.cash_inicio), false)}</td>)}
          </tr>
          <tr>
            <td class="row-label">Increase / (Decrease)</td>
            {cf.map(r => <td>{fmt(Number(r.cash_cambio))}</td>)}
          </tr>
          <tr class="total">
            <td class="row-label">End of the Year</td>
            {cf.map(r => <td>{fmt(Number(r.cash_fin), false)}</td>)}
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="fs-section">
    <div class="fs-label">Balance Sheet</div>
    <div class="fs-sub">All figures in USD millions unless stated</div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="row-label"></th>
            {years.map(y => <th>{y}</th>)}
          </tr>
        </thead>
        <tbody>
          <tr class="section-header"><td colspan="9">Assets</td></tr>
          <tr>
            <td class="row-label">Cash</td>
            {bs.map(r => <td>{fmt(Number(r.cash), false)}</td>)}
          </tr>
          <tr>
            <td class="row-label">Accounts Receivable</td>
            {bs.map(r => <td>{fmt(Number(r.cuentas_por_cobrar), false)}</td>)}
          </tr>
          <tr>
            <td class="row-label">Inventories</td>
            {bs.map(r => <td>{fmt(Number(r.inventario), false)}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">Total Current Assets</td>
            {bs.map(r => <td>{fmt(Number(r.total_activo_corriente), false)}</td>)}
          </tr>
          <tr>
            <td class="row-label">Property Plant & Equipment</td>
            {bs.map(r => <td>{fmt(Number(r.ppe), false)}</td>)}
          </tr>
          <tr class="total">
            <td class="row-label">Total Assets</td>
            {bs.map(r => <td>{fmt(Number(r.total_activos), false)}</td>)}
          </tr>
          <tr class="spacer"><td colspan="9"></td></tr>
          <tr class="section-header"><td colspan="9">Liabilities</td></tr>
          <tr>
            <td class="row-label">Accounts Payable</td>
            {bs.map(r => <td>{fmt(Number(r.cuentas_por_pagar))}</td>)}
          </tr>
          <tr>
            <td class="row-label">Revolving Credit Line</td>
            {bs.map(r => <td>{fmt(Number(r.deuda_corto_plazo))}</td>)}
          </tr>
          <tr class="subtotal">
            <td class="row-label">Total Current Liabilities</td>
            {bs.map(r => <td>{fmt(Number(r.total_pasivo_corriente))}</td>)}
          </tr>
          <tr>
            <td class="row-label">Long-Term Debt</td>
