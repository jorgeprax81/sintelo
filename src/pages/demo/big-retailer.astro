<script define:vars={{
  roicActualChart: bridge.roic_actual,
  roicPotencialChart: bridge.roic_potencial,
  leverRoiPpChart: leverRoiPp,
  leverNamesChart: bridge.levers.map((lever) => lever.nombre)
}}>
(function() {
  const s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js';
  s.onload = () => {
    const starts = [0];
    let running = roicActualChart;
    for (const delta of leverRoiPpChart) {
      starts.push(running);
      running += delta;
    }
    starts.push(0);

    const bars = [roicActualChart, ...leverRoiPpChart, roicPotencialChart];
    const colors = ['#4A8FD4', ...leverRoiPpChart.map(() => '#4A9A7A'), '#4A9A7A'];

    new Chart(document.getElementById('wfChart'), {
      type: 'bar',
      data: {
        labels: ['ROIC actual', ...leverNamesChart, 'ROIC potencial'],
        datasets: [
          { data: starts, backgroundColor: 'transparent', borderColor: 'transparent' },
          { data: bars, backgroundColor: colors, borderColor: 'transparent', borderRadius: 2 }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => {
                if(ctx.datasetIndex === 0) return null;
                const i = ctx.dataIndex;
                const lastIndex = bars.length - 1;
                if(i === 0) return 'ROIC actual: ' + roicActualChart.toFixed(1) + '%';
                if(i === lastIndex) return 'ROIC potencial: ' + roicPotencialChart.toFixed(1) + '%';
                return '+' + ctx.parsed.y.toFixed(1) + 'pp';
              }
            }
          }
        },
        scales: {
          x: { stacked: true, ticks: { color: '#7A7470', font: { size: 11 } }, grid: { display: false }, border: { color: 'rgba(255,255,255,.06)' } },
          y: { stacked: true, min: 0, suggestedMax: Math.ceil((roicPotencialChart + 2) / 2) * 2, ticks: { color: '#7A7470', font: { size: 10 }, callback: v => v + '%' }, grid: { color: 'rgba(255,255,255,0.04)' }, border: { color: 'rgba(255,255,255,.06)' } }
        }
      }
    });
  };
  document.head.appendChild(s);
})();
</script>

<script define:vars={{
  heatmapLevers: bridge.levers.map((lever) => ({
    nombre: lever.nombre,
    palanca: lever.palanca,
    color: lever.palanca === 'A - Margen' ? '#7F77DD' : '#85B7EB',
    delta_pp: lever.delta_pp,
    tiempo: lever.tiempo_captura_meses,
    facilidad: lever.facilidad_captura
  }))
}}>
(function() {
  const s = document.createElement('script');
  s.src = 'https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js';
  s.onload = () => {
    const data = heatmapLevers.map(l => ({
      x: l.tiempo,
      y: l.delta_pp,
      r: l.facilidad * 2.5,
      nombre: l.nombre,
      palanca: l.palanca,
      facilidad: l.facilidad
    }));

    new Chart(document.getElementById('hmChart'), {
      type: 'bubble',
      data: {
        datasets: heatmapLevers.map((l, i) => ({
          label: l.nombre,
          data: [data[i]],
          backgroundColor: l.color + 'CC',
          borderColor: l.color,
          borderWidth: 1.5
        }))
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => {
                const d = ctx.raw;
                return [
                  d.nombre,
                  'Impacto: +' + d.y.toFixed(1) + 'pp',
                  'Captura: ' + d.x + ' meses',
                  'Facilidad: ' + d.facilidad + '/10'
                ];
              }
            }
          }
        },
        scales: {
          x: {
            title: { display: true, text: 'Tiempo de captura (meses)', color: '#7A7470', font: { size: 11 } },
            min: 0, max: 24,
            ticks: { color: '#7A7470', font: { size: 10 }, stepSize: 6, callback: v => v + 'm' },
            grid: { color: 'rgba(255,255,255,0.04)' },
            border: { color: 'rgba(255,255,255,.06)' },
            reverse: true
          },
          y: {
            title: { display: true, text: 'Impacto en ROIC (pp)', color: '#7A7470', font: { size: 11 } },
            min: 0,
            ticks: { color: '#7A7470', font: { size: 10 }, callback: v => '+' + v + 'pp' },
            grid: { color: 'rgba(255,255,255,0.04)' },
            border: { color: 'rgba(255,255,255,.06)' }
          }
        }
      }
    });
  };
  document.head.appendChild(s);
})();
</script>

</Layout>

