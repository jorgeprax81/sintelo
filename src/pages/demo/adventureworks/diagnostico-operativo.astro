---
import Layout from '../../../layouts/Layout.astro';
import pg from 'pg';
const { Pool } = pg;
export const prerender = false;

const pool = new Pool({
  connectionString: import.meta.env.DATABASE_URL,
  ssl: { rejectUnauthorized: false }
});

const [revenueRes, margenRes, diasRes, paretoRes, mixRes, territorioRes, precioRes] = await Promise.all([
  pool.query(`SELECT ROUND(SUM(totaldue)::numeric,2) AS revenue_total FROM sales.salesorderheader WHERE status=5`),
  pool.query(`
    SELECT ROUND((SUM(soh.totaldue)-SUM(d.cogs))/SUM(soh.totaldue)*100,1) AS margen
    FROM sales.salesorderheader soh
    JOIN (SELECT salesorderid, SUM(orderqty*c.standardcost) AS cogs FROM sales.salesorderdetail sod
      JOIN (SELECT DISTINCT ON (productid) productid, standardcost FROM production.productcosthistory ORDER BY productid, startdate DESC) c ON sod.productid=c.productid
      GROUP BY salesorderid) d ON soh.salesorderid=d.salesorderid WHERE soh.status=5`),
  pool.query(`
    SELECT pc.name AS categoria, ROUND(SUM(pi.quantity*c.standardcost)/((SELECT SUM(d.orderqty*c2.standardcost) FROM sales.salesorderdetail d
      JOIN sales.salesorderheader soh ON d.salesorderid=soh.salesorderid
      JOIN (SELECT DISTINCT ON (productid) productid, standardcost FROM production.productcosthistory ORDER BY productid, startdate DESC) c2 ON d.productid=c2.productid
      WHERE soh.status=5 AND EXTRACT(YEAR FROM soh.orderdate)=2024 AND d.productid=pi.productid GROUP BY d.productid HAVING SUM(d.orderqty*c2.standardcost)>0)/365),0) AS dias
    FROM production.productinventory pi
    JOIN production.product p ON pi.productid=p.productid
    JOIN production.productsubcategory ps ON p.productsubcategoryid=ps.productsubcategoryid
    JOIN production.productcategory pc ON ps.productcategoryid=pc.productcategoryid
    JOIN (SELECT DISTINCT ON (productid) productid, standardcost FROM production.productcosthistory ORDER BY productid, startdate DESC) c ON pi.productid=c.productid
    WHERE pc.name IN ('Components','Bikes','Clothing','Accessories')
    GROUP BY pc.name ORDER BY dias DESC NULLS LAST`),
  pool.query(`
    WITH rps AS (SELECT p.productid, SUM(sod.orderqty*sod.unitprice*(1-sod.unitpricediscount)) AS revenue
      FROM sales.salesorderdetail sod JOIN sales.salesorderheader soh ON sod.salesorderid=soh.salesorderid
      JOIN production.product p ON sod.productid=p.productid WHERE soh.status=5 GROUP BY p.productid),
    ac AS (SELECT revenue, SUM(revenue) OVER (ORDER BY revenue DESC)/SUM(revenue) OVER()*100 AS pct FROM rps)
    SELECT ROUND(COUNT(*)*100.0/(SELECT COUNT(*) FROM rps),1) AS pct_skus FROM ac WHERE pct<=80`),
  pool.query(`
    SELECT pc.name AS categoria, ROUND(SUM(sod.orderqty*sod.unitprice*(1-sod.unitpricediscount))::numeric,2) AS revenue,
      ROUND(SUM(sod.orderqty*sod.unitprice*(1-sod.unitpricediscount))/SUM(SUM(sod.orderqty*sod.unitprice*(1-sod.unitpricediscount))) OVER()*100,1) AS pct
    FROM sales.salesorderheader soh JOIN sales.salesorderdetail sod ON soh.salesorderid=sod.salesorderid
    JOIN production.product p ON sod.productid=p.productid
    JOIN production.productsubcategory ps ON p.productsubcategoryid=ps.productsubcategoryid
    JOIN production.productcategory pc ON ps.productcategoryid=pc.productcategoryid
    WHERE soh.status=5 GROUP BY pc.name ORDER BY revenue DESC`),
  pool.query(`
    SELECT st.name AS territorio, ROUND(SUM(sod.orderqty*sod.unitprice*(1-sod.unitpricediscount))::numeric,2) AS revenue,
      ROUND(SUM(sod.orderqty*sod.unitprice*(1-sod.unitpricediscount))/SUM(SUM(sod.orderqty*sod.unitprice*(1-sod.unitpricediscount))) OVER()*100,1) AS pct
    FROM sales.salesorderheader soh JOIN sales.salesorderdetail sod ON sod.salesorderid=soh.salesorderid
    JOIN sales.salesterritory st ON soh.territoryid=st.territoryid
    WHERE soh.status=5 GROUP BY st.territoryid,st.name ORDER BY revenue DESC`),
  pool.query(`
    SELECT pc.name AS categoria, ROUND(AVG(p.listprice)::numeric,2) AS precio_lista, ROUND(AVG(sod.unitprice)::numeric,2) AS precio_real,
      ROUND((1-AVG(sod.unitprice)/NULLIF(AVG(p.listprice),0))*100,1) AS descuento_pct
    FROM sales.salesorderdetail sod JOIN sales.salesorderheader soh ON sod.salesorderid=soh.salesorderid
    JOIN production.product p ON sod.productid=p.productid
    JOIN production.productsubcategory ps ON p.productsubcategoryid=ps.productsubcategoryid
    JOIN production.productcategory pc ON ps.productcategoryid=pc.productcategoryid
    WHERE soh.status=5 AND p.listprice>0 GROUP BY pc.name ORDER BY descuento_pct DESC`),
]);

await pool.end();

const revenue = Number(revenueRes.rows[0].revenue_total);
const margen = Number(margenRes.rows[0].margen);
const dias = diasRes.rows;
const pctSkus = Number(paretoRes.rows[0].pct_skus);
const mix = mixRes.rows;
const territorios = territorioRes.rows;
const precios = precioRes.rows;

const diasComponents = dias.find(r => r.categoria === 'Components')?.dias || 0;

function formatM(n: number) {
  return '$' + (n / 1_000_000).toFixed(1) + 'M';
}
---

<Layout title="Sintelo — AdventureWorks · Diagnóstico Operativo">

<section class="hero">
  <div class="eyebrow"><span class="dot"></span> Diagnóstico Operativo · AdventureWorks Inc.</div>
  <h1>El portafolio es demasiado complejo.<br><em>Components destruye valor en ambas palancas.</em></h1>
  <p class="sub">Diagnóstico basado en datos operativos — ventas, inventario, costos y pricing. Sin balance sheet, el ROIC real no es calculable. Pero los hallazgos operativos son claros y accionables.</p>
  <div class="disclaimer"><span class="disc-dot"></span> Empresa de demostración: AdventureWorks Inc. — fabricante de bicicletas. Datos operativos 2022-2025.</div>
</section>

<!-- KPIs -->
<section class="section">
  <div class="label">Indicadores clave</div>
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="kpi-val">{formatM(revenue)}</div>
      <div class="kpi-name">Revenue total</div>
      <div class="kpi-sub">Órdenes completadas</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-val">{margen}%</div>
      <div class="kpi-name">Margen bruto proxy</div>
      <div class="kpi-sub">Revenue - COGS estándar</div>
    </div>
    <div class="kpi-card kpi-alert">
      <div class="kpi-val">{Number(diasComponents).toLocaleString('es-MX')}</div>
      <div class="kpi-name">Días inventario Components</div>
      <div class="kpi-sub">7+ meses de stock parado</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-val">{pctSkus}%</div>
      <div class="kpi-name">SKUs → 80% revenue</div>
      <div class="kpi-sub">Pareto de portafolio</div>
    </div>
  </div>
</section>

<!-- HALLAZGOS -->
<section class="section">
  <div class="label">Tres hallazgos operativos</div>
  <div class="hallazgos">
    <div class="hallazgo hallazgo-warn">
      <div class="h-num">01</div>
      <div class="h-lever">Lever: Complejidad de producto</div>
      <div class="h-title">{mix[0]?.pct}% del revenue viene de {mix[0]?.categoria}. El resto no justifica su complejidad.</div>
      <p class="h-body">{pctSkus}% de los SKUs generan el 80% del revenue. El {(100 - pctSkus).toFixed(1)}% restante consume inventario, atención de ventas y overhead desproporcionado. {mix.slice(2).map(r => r.categoria).join(' y ')} juntos representan solo {mix.slice(2).reduce((a,r) => a + Number(r.pct), 0).toFixed(1)}%.</p>
      <div class="h-accion">→ Palanca A · Simplificación de portafolio</div>
    </div>
    <div class="hallazgo hallazgo-warn">
      <div class="h-num">02</div>
      <div class="h-lever">Lever: Working Capital + Pricing</div>
      <div class="h-title">Components: {Number(diasComponents).toLocaleString()} días de inventario y vendido al {(100 - Number(precios.find(r => r.categoria === 'Components')?.descuento_pct || 0)).toFixed(0)}% del precio lista.</div>
      <p class="h-body">Capital inmovilizado equivalente a 7 meses de ventas de esa categoría. El descuento efectivo es del {precios.find(r => r.categoria === 'Components')?.descuento_pct}% — la categoría destruye valor en Palanca A y Palanca B al mismo tiempo.</p>
      <div class="h-accion">→ Palanca B · Liquidación + revisión de pricing</div>
    </div>
    <div class="hallazgo">
      <div class="h-num">03</div>
      <div class="h-lever">Lever: Sales Enhancement</div>
      <div class="h-title">{territorios[0]?.territorio} concentra {territorios[0]?.pct}% del revenue. {territorios[territorios.length-1]?.territorio} genera solo {territorios[territorios.length-1]?.pct}%.</div>
      <p class="h-body">North America genera el 72% del revenue. Alta dependencia geográfica que replica la concentración de producto. Europe tiene operaciones activas pero sub-penetradas — France y Germany tienen potencial sin explotar.</p>
      <div class="h-accion">→ Palanca A · Expansión geográfica selectiva</div>
    </div>
  </div>
</section>

<!-- MIX + INVENTARIO -->
<section class="section">
  <div class="label">Análisis de portafolio</div>
  <div class="charts-2col">
    <div>
      <div class="chart-sub">Revenue por categoría</div>
      <div class="mix-list">
        {mix.map(r => (
          <div class="mix-row">
            <div class="mix-name">{r.categoria}</div>
            <div class="mix-bar-wrap">
              <div class="mix-bar" style={`width:${r.pct}%`}></div>
            </div>
            <div class="mix-pct">{r.pct}%</div>
          </div>
        ))}
      </div>
      <div class="insight">El <strong>{(100-pctSkus).toFixed(0)}% del portafolio</strong> genera solo el 20% del revenue.</div>
    </div>
    <div>
      <div class="chart-sub">Días de inventario por categoría</div>
      <div class="inv-list">
        {dias.filter(r => r.dias !== null).map(r => {
          const diasNum = Number(r.dias);
          const maxDias = Number(diasComponents);
          const pct = Math.min((diasNum / maxDias) * 100, 100);
          const isAlert = diasNum > 150;
          const isWarn = diasNum > 60 && diasNum < 151;
          return (
            <div class="inv-row">
              <div class="inv-cat">{r.categoria}</div>
              <div class="inv-bar-wrap">
                <div class={`inv-bar ${isAlert ? 'inv-alert' : ''}`} style={`width:${pct}%`}></div>
              </div>
              <div class="inv-dias">{diasNum.toLocaleString()} días</div>
              <div class={`inv-badge ${isAlert ? 'badge-alert' : isWarn ? 'badge-warn' : 'badge-ok'}`}>
                {isAlert ? 'Crítico' : isWarn ? 'Monitorear' : 'Saludable'}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="section">
  <div class="label">Pricing · precio lista vs precio real</div>
  <div class="precio-list">
    {precios.map(r => {
      const realPct = 100 - Number(r.descuento_pct);
      const isOk = Number(r.descuento_pct) < 15;
      return (
        <div class="precio-row">
          <div class="precio-cat">{r.categoria}</div>
          <div class="precio-bar">
            <div class={`precio-real ${isOk ? 'precio-ok' : ''}`} style={`width:${realPct}%`}>
              <span class="precio-label">{realPct.toFixed(0)}% del lista</span>
            </div>
            <div class="precio-gap" style={`width:${r.descuento_pct}%`}>
              <span class="precio-label">-{r.descuento_pct}%</span>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<!-- TERRITORIOS -->
<section class="section">
  <div class="label">Revenue por territorio</div>
  <div class="territorio-list">
    {territorios.map(r => (
      <div class="t-row">
        <div class="t-name">{r.territorio}</div>
        <div class="t-bar-wrap">
          <div class="t-bar" style={`width:${r.pct}%`}></div>
        </div>
        <div class="t-pct">{r.pct}%</div>
      </div>
    ))}
  </div>
  <div class="insight" style="margin-top:1rem;">North America concentra el <strong>72%</strong> — alta dependencia geográfica.</div>
</section>

<!-- OPORTUNIDADES -->
<section class="section">
  <div class="label">Oportunidades identificadas</div>
  <div class="opp-grid">
    <div class="opp">
      <div class="opp-num">01 —</div>
      <div class="opp-title">Liquidar inventario de Components</div>
      <div class="opp-val">Capital liberado estimado</div>
      <p class="opp-desc">Reducir días de inventario de {Number(diasComponents).toLocaleString()} a 90 días libera capital operativo significativo. Sin balance sheet, el monto exacto requiere datos de costos totales.</p>
    </div>
    <div class="opp">
      <div class="opp-num">02 —</div>
      <div class="opp-title">Revisar política de pricing en Components</div>
      <div class="opp-val">Recuperar margen en categoría clave</div>
      <p class="opp-desc">Pasar de {(100 - Number(precios.find(r => r.categoria === 'Components')?.descuento_pct || 0)).toFixed(0)}% a 70% del precio lista en Components representa un incremento directo de margen. Requiere análisis de elasticidad de demanda.</p>
    </div>
    <div class="opp">
      <div class="opp-num">03 —</div>
      <div class="opp-title">Simplificar el {(100 - pctSkus).toFixed(0)}% de SKUs de cola</div>
      <div class="opp-val">Overhead reducido + capital liberado</div>
      <p class="opp-desc">Los SKUs fuera del Pareto consumen planificación, inventario y atención de ventas desproporcionados a su contribución de revenue.</p>
    </div>
  </div>
</section>

<!-- NOTA METODOLÓGICA -->
<section class="section">
  <div class="caveat">
    <strong>Nota metodológica —</strong> Este diagnóstico está basado en datos operativos (ventas, inventario, costos estándar). Sin estados financieros completos — P&L, Balance Sheet y Flujo de Caja — no es posible calcular el ROIC real, el capital invertido total, ni construir el Potential Report con el impacto preciso en valor. Con sus datos financieros reales, Sintelo entrega el análisis completo en días.
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="cta-inner">
    <div class="cta-tag">Sus datos. Su diagnóstico. En días.</div>
    <h2>¿Quiere ver el diagnóstico<br>de <em>su</em> empresa?</h2>
    <a href="/#contacto" class="btn-cta">Solicitar diagnóstico →</a>
    <div class="cta-note">Precio fijo · sin contrato de implementación por adelantado</div>
  </div>
</section>

</Layout>

<style>
.hero { padding: 6rem 3rem 5rem; border-bottom: 0.5px solid var(--border); max-width: 860px; }
.eyebrow { font-size: 11px; letter-spacing: .2em; color: var(--accent); text-transform: uppercase; margin-bottom: 1rem; display: flex; align-items: center; gap: .5rem; }
.dot, .disc-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); flex-shrink: 0; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:.3;} }
.hero h1 { font-family: var(--serif); font-size: clamp(28px,4vw,46px); font-weight: 400; color: #F0EBE0; line-height: 1.15; margin-bottom: 1rem; }
.hero h1 em { font-style: italic; color: var(--accent); }
.sub { font-size: 14px; color: var(--muted); line-height: 1.8; max-width: 620px; margin-bottom: 1.5rem; }
.disclaimer { display: inline-flex; align-items: center; gap: .5rem; font-size: 12px; color: var(--dim); background: rgba(74,143,212,.05); border: .5px solid var(--accent-border); padding: .5rem 1rem; }

.section { padding: 4rem 3rem; border-bottom: .5px solid var(--border); }
.label { font-size: 11px; letter-spacing: .2em; color: var(--accent); text-transform: uppercase; margin-bottom: 2rem; }
.chart-sub { font-size: 11px; color: var(--dim); margin-bottom: 1rem; letter-spacing: .04em; }

.kpi-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border); border: .5px solid var(--border); }
.kpi-card { background: var(--bg); padding: 2rem 1.75rem; }
.kpi-alert { background: rgba(212,164,74,.04); }
.kpi-val { font-family: var(--serif); font-size: clamp(28px,3.5vw,42px); font-weight: 500; color: var(--accent); line-height: 1; margin-bottom: .5rem; }
.kpi-alert .kpi-val { color: #D4A44A; }
.kpi-name { font-size: 13px; color: #C8C3B8; margin-bottom: .2rem; }
.kpi-sub { font-size: 11px; color: var(--dim); }

.hallazgos { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
.hallazgo { border: .5px solid rgba(255,255,255,.07); padding: 2rem; }
.hallazgo-warn { border-color: rgba(212,164,74,.2); background: rgba(212,164,74,.02); }
.h-num { font-family: var(--serif); font-size: 40px; color: var(--accent); opacity: .15; line-height: 1; margin-bottom: .4rem; }
.hallazgo-warn .h-num { color: #D4A44A; }
.h-lever { font-size: 10px; letter-spacing: .15em; color: var(--accent); text-transform: uppercase; margin-bottom: .6rem; }
.hallazgo-warn .h-lever { color: #D4A44A; }
.h-title { font-family: var(--serif); font-size: 16px; color: #F0EBE0; line-height: 1.3; margin-bottom: .75rem; }
.h-body { font-size: 12px; color: var(--dim); line-height: 1.8; margin-bottom: 1rem; }
.h-accion { font-size: 10px; color: var(--accent); border-top: .5px solid rgba(255,255,255,.06); padding-top: .75rem; }
.hallazgo-warn .h-accion { color: #D4A44A; border-color: rgba(212,164,74,.15); }

.charts-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
.mix-list { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 1rem; }
.mix-row { display: grid; grid-template-columns: 90px 1fr 45px; gap: .75rem; align-items: center; }
.mix-name { font-size: 12px; color: var(--muted); }
.mix-bar-wrap { height: 22px; background: rgba(255,255,255,.03); border: .5px solid rgba(255,255,255,.06); }
.mix-bar { height: 100%; background: var(--accent); opacity: .55; }
.mix-pct { font-size: 12px; color: #C8C3B8; text-align: right; }

.inv-list { display: flex; flex-direction: column; gap: .75rem; }
.inv-row { display: grid; grid-template-columns: 90px 1fr 70px 75px; gap: .75rem; align-items: center; }
.inv-cat { font-size: 12px; color: var(--muted); }
.inv-bar-wrap { height: 20px; background: rgba(255,255,255,.03); border: .5px solid rgba(255,255,255,.06); }
.inv-bar { height: 100%; background: var(--accent); opacity: .5; }
.inv-alert { background: #D4A44A; opacity: .6; }
.inv-dias { font-size: 11px; color: #C8C3B8; }
.inv-badge { font-size: 9px; letter-spacing: .06em; text-transform: uppercase; padding: .15rem .35rem; text-align: center; border: .5px solid; }
.badge-ok { color: #4A9A7A; border-color: rgba(74,154,122,.3); }
.badge-warn { color: #D4A44A; border-color: rgba(212,164,74,.3); }
.badge-alert { color: #D4A44A; border-color: rgba(212,164,74,.3); }

.insight { font-size: 12px; color: var(--dim); border-top: .5px solid var(--border); padding-top: .75rem; }
.insight strong { color: var(--accent); font-weight: 400; }

.precio-list { display: flex; flex-direction: column; gap: 1rem; max-width: 700px; }
.precio-row { display: grid; grid-template-columns: 100px 1fr; gap: 1rem; align-items: center; }
.precio-cat { font-size: 12px; color: var(--muted); }
.precio-bar { height: 28px; display: flex; }
.precio-real { background: var(--accent); opacity: .45; display: flex; align-items: center; padding-left: .4rem; }
.precio-ok { background: #4A9A7A; opacity: .5; }
.precio-gap { background: rgba(212,164,74,.3); display: flex; align-items: center; justify-content: center; }
.precio-label { font-size: 9px; color: rgba(255,255,255,.75); letter-spacing: .04em; white-space: nowrap; }

.territorio-list { display: flex; flex-direction: column; gap: .6rem; max-width: 700px; }
.t-row { display: grid; grid-template-columns: 130px 1fr 45px; gap: .75rem; align-items: center; }
.t-name { font-size: 12px; color: var(--muted); }
.t-bar-wrap { height: 18px; background: rgba(255,255,255,.03); border: .5px solid rgba(255,255,255,.06); }
.t-bar { height: 100%; background: #3A7A6A; opacity: .55; }
.t-pct { font-size: 11px; color: #C8C3B8; text-align: right; }

.opp-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; }
.opp { border: .5px solid rgba(255,255,255,.07); padding: 1.5rem; }
.opp-num { font-size: 10px; letter-spacing: .1em; color: var(--accent); margin-bottom: .6rem; }
.opp-title { font-family: var(--serif); font-size: 15px; color: #E8E3D8; line-height: 1.3; margin-bottom: .5rem; }
.opp-val { font-size: 12px; color: #4A9A7A; margin-bottom: .5rem; font-weight: 500; }
.opp-desc { font-size: 12px; color: var(--dim); line-height: 1.7; }

.caveat { font-size: 13px; color: var(--dim); background: rgba(74,143,212,.04); border: .5px solid rgba(74,143,212,.15); padding: 1.25rem 1.5rem; line-height: 1.8; max-width: 800px; }
.caveat strong { color: var(--accent); font-weight: 400; }

.cta-section { padding: 7rem 3rem; text-align: center; }
.cta-inner { max-width: 600px; margin: 0 auto; }
.cta-tag { font-size: 11px; letter-spacing: .15em; color: var(--accent); text-transform: uppercase; margin-bottom: 1.5rem; }
.cta-section h2 { font-family: var(--serif); font-size: clamp(28px,4vw,46px); color: #F0EBE0; font-weight: 400; line-height: 1.1; margin-bottom: 2rem; }
.cta-section h2 em { font-style: italic; color: var(--accent); }
.btn-cta { display: inline-block; background: var(--accent); color: #fff; padding: 1rem 2.5rem; font-family: var(--sans); font-size: 14px; font-weight: 500; letter-spacing: .06em; transition: opacity .2s; margin-bottom: 1rem; }
.btn-cta:hover { opacity: .88; }
.cta-note { font-size: 12px; color: var(--dim); letter-spacing: .04em; }

@media (max-width: 900px) {
  .kpi-grid { grid-template-columns: 1fr 1fr; }
  .hallazgos, .charts-2col, .opp-grid { grid-template-columns: 1fr; }
}
