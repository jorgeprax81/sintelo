---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout title={`${post.data.titulo} — Sintelo`} description={post.data.descripcion}>

<article class="post-layout">

  <header class="post-header">
    <a href="/blog" class="back">← Blog</a>
    <div class="post-tag">{post.data.categoria}</div>
    <h1>{post.data.titulo}</h1>
    <div class="post-date">{formatDate(post.data.fecha)}</div>
  </header>

  <div class="post-body">
    <Content />
  </div>

  <footer class="post-footer">
    <div class="cta-block">
      <div class="cta-title">¿Quiere aplicar esto a su empresa?</div>
      <p class="cta-text">El diagnóstico de Sintelo incluye este análisis como punto de partida — y lo cuantifica en pesos.</p>

      <form class="contact-form" id="contact-form">
        <div class="form-row">
          <div class="form-group">
            <label for="nombre">Nombre</label>
            <input type="text" id="nombre" name="nombre" placeholder="Su nombre" required />
          </div>
          <div class="form-group">
            <label for="empresa">Empresa</label>
            <input type="text" id="empresa" name="empresa" placeholder="Nombre de la empresa" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Correo electrónico</label>
          <input type="email" id="email" name="email" placeholder="su@correo.com" required />
        </div>
        <button type="submit" class="btn-primary" id="btn-submit">Solicitar diagnóstico →</button>
      </form>

      <div class="gracias" id="gracias" style="display:none">
        <div class="gracias-titulo">Gracias — nos pondremos en contacto pronto.</div>
        <p class="gracias-sub">Revisamos cada solicitud personalmente y le escribiremos en las próximas 24 horas.</p>
      </div>

      <script>
        document.getElementById('contact-form').addEventListener('submit', async function(e) {
          e.preventDefault();
          const btn = document.getElementById('btn-submit');
          btn.textContent = 'Enviando...';
          btn.disabled = true;
          const data = new FormData(this);
          const response = await fetch('https://formspree.io/f/mreokgle', {
            method: 'POST',
            body: data,
            headers: { 'Accept': 'application/json' }
          });
          if (response.ok) {
            document.getElementById('contact-form').style.display = 'none';
            document.getElementById('gracias').style.display = 'block';
          } else {
            btn.textContent = 'Error — intente de nuevo';
            btn.disabled = false;
          }
        });
      </script>
    </div>
    <a href="/blog" class="btn-outline">← Ver todos los artículos</a>
  </footer>

</article>

</Layout>

<style>
.post-layout {
  max-width: 720px;
  margin: 0 auto;
  padding: 4rem 2rem 6rem;
}

.post-header {
  margin-bottom: 3rem;
  padding-bottom: 2rem;
  border-bottom: 0.5px solid var(--border);
}

.back {
  display: inline-block;
  font-size: 12px;
  color: var(--muted);
  letter-spacing: 0.04em;
  margin-bottom: 2rem;
  transition: color 0.2s;
}
.back:hover { color: var(--accent); }

.post-tag {
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
}

.post-header h1 {
  font-family: var(--serif);
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 400;
  color: #F0EBE0;
  line-height: 1.2;
  margin-bottom: 1.25rem;
}

.post-date { font-size: 13px; color: #5A5450; }

/* POST BODY TYPOGRAPHY */
.post-body { color: var(--muted); line-height: 1.85; font-size: 16px; }

.post-body :global(h2) {
  font-family: var(--serif);
  font-size: 28px;
  font-weight: 400;
  color: #E8E3D8;
  margin: 2.5rem 0 1rem;
  line-height: 1.3;
}

.post-body :global(h3) {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 400;
  color: #E8E3D8;
  margin: 2rem 0 0.75rem;
}

.post-body :global(p) { margin-bottom: 1.25rem; }

.post-body :global(strong) {
  color: #C8C3B8;
  font-weight: 500;
}

.post-body :global(em) {
  color: var(--accent);
  font-style: italic;
}

.post-body :global(pre) {
  background: rgba(255,255,255,0.04);
  border: 0.5px solid var(--border);
  padding: 1.25rem 1.5rem;
  margin: 1.5rem 0;
  font-size: 14px;
  overflow-x: auto;
  font-family: 'Courier New', monospace;
  color: #B0C4DE;
  line-height: 1.6;
}

.post-body :global(code) {
  font-family: 'Courier New', monospace;
  font-size: 14px;
  color: #B0C4DE;
}

.post-body :global(ul), .post-body :global(ol) {
  margin: 1rem 0 1.25rem 1.5rem;
}

.post-body :global(li) { margin-bottom: 0.5rem; }

.post-body :global(hr) {
  border: none;
  border-top: 0.5px solid var(--border);
  margin: 3rem 0;
}

.post-body :global(blockquote) {
  border-left: 2px solid var(--accent);
  padding-left: 1.5rem;
  margin: 1.5rem 0;
  color: #9A9488;
  font-style: italic;
}

/* FOOTER */
.post-footer {
  margin-top: 4rem;
  padding-top: 3rem;
  border-top: 0.5px solid var(--border);
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.cta-block {
  background: rgba(74,143,212,0.05);
  border: 0.5px solid var(--accent-border);
  padding: 2rem;
}

.cta-title {
  font-family: var(--serif);
  font-size: 22px;
  color: #F0EBE0;
  margin-bottom: 0.75rem;
}

.cta-text { font-size: 14px; color: var(--dim); margin-bottom: 1.5rem; }

.btn-primary {
  display: inline-block;
  background: var(--accent);
  color: #fff;
  padding: 0.75rem 2rem;
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.06em;
  transition: opacity 0.2s;
}
.btn-primary:hover { opacity: 0.88; }

.btn-outline {
  display: inline-block;
  color: var(--muted);
  font-size: 13px;
  letter-spacing: 0.04em;
  transition: color 0.2s;
}
.btn-outline:hover { color: var(--accent); }

.contact-form { margin-top: 1.5rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
.form-group label { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }
.form-group input {
  background: rgba(255,255,255,0.03);
  border: 0.5px solid rgba(255,255,255,0.12);
  color: var(--text);
  padding: 0.75rem 1rem;
  font-family: var(--sans);
  font-size: 14px;
  font-weight: 300;
  outline: none;
  transition: border-color 0.2s;
}
.form-group input::placeholder { color: #4A4440; }
.form-group input:focus { border-color: var(--accent); }
.gracias { padding: 2rem; background: rgba(74,143,212,0.04); border: 0.5px solid var(--accent-border); margin-top: 1rem; }
.gracias-titulo { font-family: var(--serif); font-size: 22px; color: #F0EBE0; margin-bottom: 0.5rem; }
.gracias-sub { font-size: 13px; color: var(--dim); line-height: 1.7; }
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }
</style>
