---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sintelo — Acceso">
<section class="login-section">
  <div class="login-card">
    <div class="login-logo">Sintelo</div>
    <h1>Acceso a su diagnóstico</h1>
    <p class="login-sub">Ingrese su correo para recibir un enlace de acceso.</p>
    
    <form id="login-form">
      <div class="form-group">
        <label for="email">Correo electrónico</label>
        <input type="email" id="email" placeholder="su@empresa.com" required />
      </div>
      <button type="submit" class="btn-login" id="btn-login">
        Enviar enlace de acceso →
      </button>
    </form>

    <div id="mensaje" class="mensaje" style="display:none"></div>
  </div>
</section>

<script>
  import { supabase } from '../lib/supabase';

  document.getElementById('login-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-login');
    const mensaje = document.getElementById('mensaje');
    const email = document.getElementById('email').value;
    
    btn.textContent = 'Enviando...';
    btn.disabled = true;

    const { error } = await supabase.auth.signInWithOtp({
      email,
      options: {
        emailRedirectTo: `${window.location.origin}/app`
      }
    });

    if (error) {
      mensaje.textContent = 'Error: ' + error.message;
      mensaje.className = 'mensaje error';
      btn.textContent = 'Enviar enlace de acceso →';
      btn.disabled = false;
    } else {
      mensaje.textContent = 'Revise su correo — le enviamos un enlace de acceso.';
      mensaje.className = 'mensaje ok';
      document.getElementById('login-form').style.display = 'none';
    }
    mensaje.style.display = 'block';
  });
</script>
</Layout>

<style>
.login-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}
.login-card {
  max-width: 420px;
  width: 100%;
  border: 0.5px solid var(--border);
  padding: 3rem 2.5rem;
}
.login-logo {
  font-family: var(--serif);
  font-size: 22px;
  color: var(--accent);
  margin-bottom: 2rem;
  letter-spacing: 0.05em;
}
.login-card h1 {
  font-family: var(--serif);
  font-size: 26px;
  color: #F0EBE0;
  font-weight: 400;
  margin-bottom: 0.75rem;
  line-height: 1.2;
}
.login-sub {
  font-size: 13px;
  color: var(--dim);
  margin-bottom: 2rem;
  line-height: 1.7;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  margin-bottom: 1rem;
}
.form-group label {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
}
.form-group input {
  background: rgba(255,255,255,0.03);
  border: 0.5px solid rgba(255,255,255,0.12);
  color: var(--text);
  padding: 0.75rem 1rem;
  font-family: var(--sans);
  font-size: 14px;
  outline: none;
  transition: border-color 0.2s;
}
.form-group input:focus { border-color: var(--accent); }
.btn-login {
  width: 100%;
  background: var(--accent);
  color: #fff;
  border: none;
  padding: 0.9rem 2rem;
  font-family: var(--sans);
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: opacity 0.2s;
  margin-top: 0.5rem;
}
.btn-login:hover { opacity: 0.88; }
.mensaje {
  font-size: 13px;
  padding: 1rem;
  margin-top: 1rem;
  line-height: 1.6;
}
.mensaje.ok {
  color: #4A9A7A;
  border: 0.5px solid rgba(74,154,122,0.3);
  background: rgba(74,154,122,0.05);
}
.mensaje.error {
  color: #D44A4A;
  border: 0.5px solid rgba(212,74,74,0.3);
  background: rgba(212,74,74,0.05);
}
</style>
