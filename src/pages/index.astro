---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout>

<!-- HERO -->
<section class="hero">
  <div class="eyebrow">Capital Allocation Advisory · Tampico, México</div>
  <h1>Encontramos el valor <em>oculto</em><br>en su empresa.</h1>
  <p class="hero-sub">La mayoría de los dueños de empresas industriales conocen sus ventas y su EBITDA. Pocos saben cuánto capital tienen invertido — y qué retorno genera ese capital.</p>
  <div class="hero-ctas">
    <a href="#contacto" class="btn-primary">Solicitar diagnóstico</a>
    <a href="#metodologia" class="btn-secondary">Ver cómo funciona</a>
  </div>
</section>

<!-- NUMBER STRIP -->
<div class="number-strip">
  <div class="number-item">
    <div class="number-val">+6pp</div>
    <div class="number-label">mejora de margen EBITDA</div>
  </div>
  <div class="number-item">
    <div class="number-val">40%</div>
    <div class="number-label">reducción de working capital</div>
  </div>
  <div class="number-item">
    <div class="number-val">+10pp</div>
    <div class="number-label">incremento de ROIC</div>
  </div>
</div>

<!-- EL PROBLEMA -->
<section id="problema" class="section">
  <div class="label">El problema</div>
  <h2>¿Cuánto vale realmente su empresa<br>— y qué la está frenando?</h2>
  <p class="section-body">La mayoría de los dueños conocen sus ventas y su EBITDA. Pocos saben cuánto capital tienen invertido, qué retorno genera ese capital — y dónde están perdiendo valor cada día.</p>
  <div class="problema-grid">
    <div class="pain">
      <div class="pain-title">Capital atrapado en operaciones</div>
      <p class="pain-text">Inventario excesivo, clientes que pagan tarde, activos subutilizados. El dinero está en el negocio pero no trabaja.</p>
    </div>
    <div class="pain">
      <div class="pain-title">Margen que se escapa sin que nadie lo vea</div>
      <p class="pain-text">Productos que se venden pero no generan utilidad real. Costos de procurement sin negociación. Overhead que creció con los años.</p>
    </div>
    <div class="pain">
      <div class="pain-title">Decisiones de inversión sin criterio de retorno</div>
      <p class="pain-text">Capex basado en intuición. Sin un ROIC mínimo requerido. Sin saber si el siguiente peso invertido genera valor o lo destruye.</p>
    </div>
    <div class="pain pain-accent">
      <div class="pain-title">Estos no son problemas de gestión.</div>
      <p class="pain-text">Son problemas de información y de claridad económica.</p>
    </div>
  </div>
</section>

<!-- TESIS ROIC -->
<section class="section">
  <div class="label">Nuestra tesis</div>
  <h2>El ROIC es el número más importante<br>de su empresa.</h2>
  <p class="section-body">El retorno sobre capital invertido se mueve en dos palancas. Cada decisión operativa mueve una de ellas. Nuestro trabajo es hacerlo visible — y ejecutable.</p>
  <div class="roic-formula">
    <span class="roic-acronym">ROIC</span>
    <span class="roic-eq">=</span>
    <div class="roic-fraction">
      <div class="roic-num">NOPAT (utilidad operativa neta)</div>
      <div class="roic-line"></div>
      <div class="roic-den">Capital Invertido (activos operativos)</div>
    </div>
  </div>
  <div class="roic-grid">
    <div class="palanca">
      <div class="palanca-label">Palanca A</div>
      <div class="palanca-title">Margen operativo</div>
      <div class="palanca-items">Pricing · Costos · Mezcla de productos</div>
      <div class="palanca-arrow">→ Mueve el NOPAT</div>
    </div>
    <div class="palanca">
      <div class="palanca-label">Palanca B</div>
      <div class="palanca-title">Rotación de capital</div>
      <div class="palanca-items">Working capital · Activos · Capex</div>
      <div class="palanca-arrow">→ Mueve el capital invertido</div>
    </div>
  </div>
</section>

<!-- METODOLOGÍA -->
<section id="metodologia" class="section">
  <div class="label">Lo que hace Sintelo</div>
  <h2>Un programa estructurado para maximizar<br>el ROIC de su empresa.</h2>
  <div class="fases-grid">
    <div class="fase">
      <div class="fase-num">1</div>
      <div class="fase-title">Diagnóstico</div>
      <div class="fase-time">2–6 semanas</div>
      <ul class="fase-list">
        <li>Solicitud de datos financieros y operativos</li>
        <li>Escaneo de la cadena de valor</li>
        <li>Cálculo de ROIC actual</li>
        <li>Benchmarking vs. sector</li>
        <li>Heatmap de levers por impacto</li>
      </ul>
    </div>
    <div class="fase">
      <div class="fase-num">2</div>
      <div class="fase-title">Priorización</div>
      <div class="fase-time">1–2 semanas</div>
      <ul class="fase-list">
        <li>Matriz impacto vs. esfuerzo</li>
        <li>Quick wins (primeros 90 días)</li>
        <li>Roadmap de olas</li>
        <li>Business case cuantificado</li>
        <li>Plan de implementación</li>
      </ul>
    </div>
    <div class="fase">
      <div class="fase-num">3</div>
      <div class="fase-title">Implementación</div>
      <div class="fase-time">12–24 meses</div>
      <ul class="fase-list">
        <li>Ejecución por olas</li>
        <li>Dashboard mensual de ROIC</li>
        <li>Tracking de ahorro acumulado</li>
        <li>Capacidades internas instaladas</li>
        <li>Informe final de valor creado</li>
      </ul>
    </div>
  </div>
</section>

<!-- 10 LEVERS -->
<section class="section">
  <div class="label">La metodología</div>
  <h2>Analizamos la cadena de valor completa.</h2>
  <p class="section-body">El diagnóstico define cuáles de los 10 levers tienen mayor impacto en su empresa específica.</p>
  <div class="levers-grid">
    <div class="lever-group">
      <div class="lever-group-title">Revenue improvement</div>
      <div class="lever-item">Pricing optimization</div>
      <div class="lever-item">Sales enhancement</div>
    </div>
    <div class="lever-group">
      <div class="lever-group-title">Reducción de costos</div>
      <div class="lever-item">Procurement</div>
      <div class="lever-item">Producción</div>
      <div class="lever-item">Distribución</div>
      <div class="lever-item">Postventa</div>
      <div class="lever-item">Overhead</div>
      <div class="lever-item">IT</div>
      <div class="lever-item">Complejidad de producto</div>
      <div class="lever-item">Costos de producto</div>
    </div>
    <div class="lever-group">
      <div class="lever-group-title">Capital</div>
      <div class="lever-item">Working capital</div>
      <div class="lever-item">Optimización de capex</div>
    </div>
  </div>
</section>

<!-- SERVICIOS -->
<section id="servicios" class="section">
  <div class="label">Cómo trabajamos</div>
  <h2>Cuatro formas de trabajar juntos.</h2>
  <div class="services-grid">
    <div class="service">
      <div class="service-num">01 —</div>
      <div class="service-title">Diagnóstico de capital</div>
      <p class="service-desc">Calculamos su ROIC actual y lo descomponemos. Identificamos las 3 a 5 palancas de mayor impacto y las cuantificamos en pesos. Al final: ROIC actual, ROIC potencial, y una recomendación clara de qué atacar primero.</p>
      <div class="service-tag">Precio fijo · entrega en 2–4 semanas · sin compromiso de implementación</div>
    </div>
    <div class="service">
      <div class="service-num">02 —</div>
      <div class="service-title">Implementación acelerada</div>
      <p class="service-desc">Con el diagnóstico en mano, nos metemos a la operación semana a semana. Frameworks de ejecución, seguimiento de iniciativas, valor capturado en 30 a 120 días.</p>
      <div class="service-tag">Retainer de 90–120 días · cadencia semanal</div>
    </div>
    <div class="service">
      <div class="service-num">03 —</div>
      <div class="service-title">Monitoreo mensual de ROIC</div>
      <p class="service-desc">Dashboard de ROIC actualizado automáticamente, informe mensual de una página, revisión con el equipo directivo una vez al mes. Disciplina de capital a largo plazo.</p>
      <div class="service-tag">Retainer mensual · largo plazo</div>
    </div>
    <div class="service">
      <div class="service-num">04 —</div>
      <div class="service-title">Due diligence operacional</div>
      <p class="service-desc">Los mismos modelos del diagnóstico aplicados a una empresa que usted quiere adquirir. ROIC histórico real, capital de trabajo verdadero, y potencial de mejora post-adquisición — antes de cerrar el trato.</p>
      <div class="service-tag">Para compradores estratégicos, family offices y fondos de private equity</div>
    </div>
  </div>
</section>

<!-- RESULTADOS -->
<section id="resultados" class="section">
  <div class="label">Resultados típicos</div>
  <h2>En empresas industriales medianas.</h2>
  <p class="section-body">Rangos basados en programas de performance improvement en manufactura, alimentos y distribución.</p>
  <div class="resultados-nums">
    <div class="resultado-num">
      <div class="resultado-val">+3–6pp</div>
      <div class="resultado-label">mejora de margen EBITDA</div>
    </div>
    <div class="resultado-num">
      <div class="resultado-val">20–40%</div>
      <div class="resultado-label">reducción de working capital</div>
    </div>
    <div class="resultado-num">
      <div class="resultado-val">+4–10pp</div>
      <div class="resultado-label">incremento de ROIC</div>
    </div>
  </div>
  <div class="resultados-ejemplos">
    <div class="ejemplo">Una empresa con $100M en ventas y 8% de EBITDA que mejora 4 puntos genera <strong>$4M anuales adicionales en flujo</strong> — sin tocar las ventas.</div>
    <div class="ejemplo">Una reducción de 30% en working capital <strong>libera capital que puede reinvertirse o distribuirse hoy.</strong></div>
    <div class="ejemplo">El programa se paga solo — <strong>generalmente en el primer trimestre de implementación.</strong></div>
  </div>
</section>

<!-- POR QUÉ AHORA -->
<section class="section">
  <div class="label">El momento importa</div>
  <h2>¿Por qué hacer esto ahora?</h2>
  <div class="ahora-grid">
    <div class="ahora-item">
      <div class="ahora-num">01</div>
      <div class="ahora-title">El costo del capital subió y no bajará pronto</div>
      <p class="ahora-text">Con tasas altas, tener capital atrapado en inventario o cuentas por cobrar tiene un costo real y creciente. Cada día de retraso en liberarlo tiene precio.</p>
    </div>
    <div class="ahora-item">
      <div class="ahora-num">02</div>
      <div class="ahora-title">Sus competidores ya están optimizando</div>
      <p class="ahora-text">Las empresas que mejoran su ROIC primero consolidan ventajas de costo y escala. Las que esperan se encuentran compitiendo con estructuras más eficientes.</p>
    </div>
    <div class="ahora-item">
      <div class="ahora-num">03</div>
      <div class="ahora-title">El diagnóstico es el primer paso, no el compromiso</div>
      <p class="ahora-text">No tiene que comprometerse a un programa de 24 meses. El diagnóstico es independiente y ya tiene valor por sí mismo como herramienta de decisión.</p>
    </div>
  </div>
</section>

<!-- POR QUÉ SINTELO -->
<section class="section">
  <div class="label">Por qué Sintelo</div>
  <h2>Lo que nos diferencia de una<br>consultoría tradicional.</h2>
  <div class="diferenciadores-grid">
    <div class="diferenciador">
      <div class="dif-title">Lente de ROIC total — no ROI por proyecto</div>
      <p class="dif-text">Evaluamos cada iniciativa en términos de su impacto en el ROIC total de la empresa. No vendemos ahorros aislados por área.</p>
    </div>
    <div class="diferenciador">
      <div class="dif-title">Claridad antes del compromiso</div>
      <p class="dif-text">El diagnóstico le da un número: ROIC actual y ROIC potencial. Usted decide si quiere ejecutar. Sin contratos de implementación por adelantado.</p>
    </div>
    <div class="diferenciador">
      <div class="dif-title">Diagnóstico en semanas, no en meses</div>
      <p class="dif-text">Metodología analítica potenciada por IA. Entregamos el diagnóstico inicial en 2–4 semanas con datos concretos.</p>
    </div>
    <div class="diferenciador">
      <div class="dif-title">Socio de largo plazo, no consultor de paso</div>
      <p class="dif-text">Nuestro modelo está diseñado para acompañar la implementación y monitorear el ROIC mes a mes — no entregar un reporte y desaparecer.</p>
    </div>
  </div>
</section>

<!-- DEMO -->
<section id="demo" class="section">
  <div class="label">En acción</div>
  <h2>Vea cómo funciona un diagnóstico real.</h2>
  <p class="section-body">Este diagnóstico usa estados financieros completos — P&L, Balance y Flujo de Caja — para calcular el ROIC real de un retailer global con 8 años de historia financiera.</p>
  <div class="demo-card" style="margin-bottom: 1.5rem">
    <div class="demo-left">
      <div class="demo-tag">Diagnóstico con estados financieros</div>
      <div class="demo-company">Big Retailer Inc.</div>
      <p class="demo-desc">Retailer global · $559B en revenue · 8 años de estados financieros completos</p>
      <div class="demo-hallazgos">
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">01</div><div class="demo-hallazgo-text">ROIC cayó de 13.2% a 5.6% en 4 años — capital creciendo más que retornos</div></div>
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">02</div><div class="demo-hallazgo-text">SG&A creció 25% mientras revenue creció 15% — overhead sin control</div></div>
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">03</div><div class="demo-hallazgo-text">Inventario saltó $20B en un año sin explicación — señal de alerta crítica</div></div>
      </div>
    </div>
    <div class="demo-right">
      <div class="demo-impacto-label">Valor capturable estimado</div>
      <div class="demo-impacto-val">$36B</div>
      <div class="demo-impacto-sub">en tres iniciativas prioritarias</div>
      <div class="demo-items">
        <div class="demo-item"><div class="demo-item-desc">Recuperar 2pp de EBITDA vía reducción de overhead</div><div class="demo-item-val">~$11B</div></div>
        <div class="demo-item"><div class="demo-item-desc">Normalizar inventario de $65B a $48B</div><div class="demo-item-val">~$17B</div></div>
      </div>
      <a href="/demo/big-retailer" class="btn-demo">Ver diagnóstico completo →</a>
    </div>
  </div>
  <p class="section-body">Este es el análisis que Sintelo realizó sobre AdventureWorks Inc. — un fabricante de bicicletas con operaciones en Norteamérica, Europa y Pacífico. Los datos son reales, calculados en tiempo real desde nuestra base de datos.</p>
  <div class="demo-card">
    <div class="demo-left">
      <div class="demo-tag">Diagnóstico ROIC</div>
      <div class="demo-company">AdventureWorks Inc.</div>
      <p class="demo-desc">Fabricante de bicicletas · $123M en revenue · Norteamérica, Europa y Pacífico</p>
      <div class="demo-hallazgos">
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">01</div><div class="demo-hallazgo-text">Components con 224 días de inventario — capital inmovilizado crítico</div></div>
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">02</div><div class="demo-hallazgo-text">86% del revenue concentrado en una sola categoría — fragilidad estructural</div></div>
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">03</div><div class="demo-hallazgo-text">72% de dependencia geográfica en Norteamérica — riesgo de concentración</div></div>
      </div>
    </div>
    <div class="demo-right">
      <div class="demo-impacto-label">Valor capturable estimado</div>
      <div class="demo-impacto-val">$3.6M</div>
      <div class="demo-impacto-sub">en tres iniciativas prioritarias</div>
      <div class="demo-items">
        <div class="demo-item"><div class="demo-item-desc">Reducir inventario Components de 224 a 90 días</div><div class="demo-item-val">~$2.4M</div></div>
        <div class="demo-item"><div class="demo-item-desc">Recuperar 10pp de descuento en Components</div><div class="demo-item-val">~$1.2M</div></div>
      </div>
      <a href="/demo" class="btn-demo">Ver diagnóstico completo →</a>
    </div>
  </div>
</section>

<!-- BLOG -->
<section id="blog" class="section">
  <div class="label">Blog</div>
  <h2>Ideas sobre capital, operaciones<br>y valor en empresas industriales.</h2>
  <div class="blog-grid">
    {posts.map(post => (
      <a href={`/blog/${post.slug}`} class="post-card">
        <div class="post-tag">{post.data.categoria}</div>
        <div class="post-title">{post.data.titulo}</div>
        <p class="post-excerpt">{post.data.descripcion}</p>
        <div class="post-meta">
          <span>{formatDate(post.data.fecha)}</span>
          <span class="post-read">Leer →</span>
        </div>
      </a>
    ))}
  </div>
  <div class="blog-cta">
    <a href="/blog" class="btn-outline">Ver todos los artículos →</a>
  </div>
</section>

<!-- JORGE -->
<section id="jorge" class="section">
  <div class="label">Quién es Sintelo</div>
  <div class="about-grid">
    <div class="about-left">
      <div class="avatar">JC</div>
      <div class="about-name">Jorge Castro</div>
      <div class="about-role">Fundador · Tampico, México</div>
      <p class="about-bio">Ingeniería industrial · Analítica · Transformación operativa. Sintelo opera en la intersección de finanzas, operaciones y analítica — con un solo objetivo: hacer que su capital genere más retorno.</p>
    </div>
    <div class="about-right">
      <div class="exp-group">
        <div class="exp-group-label">Formación</div>
        <div class="exp-item">
          <div class="exp-company">ITESM</div>
          <div class="exp-role">Ingeniería Industrial</div>
        </div>
        <div class="exp-item">
          <div class="exp-company">Carnegie Mellon University</div>
          <div class="exp-role">MSc in Information Systems Management</div>
        </div>
        <div class="exp-item">
          <div class="exp-company">ITESM</div>
          <div class="exp-role">MSc in Management of IT</div>
        </div>
      </div>
      <div class="exp-group">
        <div class="exp-group-label">Experiencia</div>
        <div class="exp-item">
          <div class="exp-company">London Consulting Group · 6 años</div>
          <div class="exp-role">Director de Business Intelligence · Transformación operativa en LATAM, EE.UU. y Canadá · +$25M USD en mejoras documentadas</div>
        </div>
        <div class="exp-item">
          <div class="exp-company">Microsoft Azure</div>
          <div class="exp-role">Supply Chain y analítica aplicada a operaciones industriales</div>
        </div>
        <div class="exp-item">
          <div class="exp-company">Accenture</div>
          <div class="exp-role">Integración de adquisiciones · Due diligence operativo</div>
        </div>
        <div class="exp-item last">
          <div class="exp-company">Elanboard · Fundador</div>
          <div class="exp-role">ERP / SAP B1 para empresas manufactureras en México</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRÓXIMOS PASOS -->
<section class="section">
  <div class="label">Cómo empezar</div>
  <h2>Empiece con el diagnóstico.</h2>
  <p class="section-body">Un primer paso concreto, de precio fijo, sin compromiso de implementación. Al final tiene un análisis concreto de su empresa — úselo para decidir qué sigue.</p>
  <div class="pasos-grid">
    <div class="paso">
      <div class="paso-num">1</div>
      <div class="paso-title">NDA firmado</div>
      <p class="paso-text">Acordamos confidencialidad antes de compartir cualquier dato.</p>
    </div>
    <div class="paso-sep">→</div>
    <div class="paso">
      <div class="paso-num">2</div>
      <div class="paso-title">Kick-off + solicitud de datos</div>
      <p class="paso-text">Enviamos el checklist de información. Reunión de 1 hora.</p>
    </div>
    <div class="paso-sep">→</div>
    <div class="paso">
      <div class="paso-num">3</div>
      <div class="paso-title">Diagnóstico en 2–4 semanas</div>
      <p class="paso-text">Su ROIC actual, ROIC potencial y las palancas priorizadas.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section id="contacto" class="cta-section">
  <h2>Encontramos el valor oculto<br>en su empresa.</h2>
  <p class="cta-sub">Precio fijo · entrega en 2–4 semanas · sin contrato de implementación por adelantado.</p>

  <form class="contact-form" id="contact-form">
    <div class="form-row">
      <div class="form-group">
        <label for="nombre">Nombre</label>
        <input type="text" id="nombre" name="nombre" placeholder="Su nombre" required />
      </div>
      <div class="form-group">
        <label for="empresa">Empresa</label>
        <input type="text" id="empresa" name="empresa" placeholder="Nombre de la empresa" required />
      </div>
    </div>
    <div class="form-group">
      <label for="email">Correo electrónico</label>
      <input type="email" id="email" name="email" placeholder="su@correo.com" required />
    </div>
    <div class="form-group">
      <label for="mensaje">¿Qué quiere mejorar en su empresa?</label>
      <textarea id="mensaje" name="mensaje" rows="4" placeholder="Cuéntenos brevemente sobre su empresa y qué le gustaría mejorar..."></textarea>
    </div>
    <button type="submit" class="btn-submit" id="btn-submit">Solicitar diagnóstico →</button>
  </form>

  <div class="gracias" id="gracias" style="display:none">
    <div class="gracias-titulo">Gracias — nos pondremos en contacto pronto.</div>
    <p class="gracias-sub">Revisamos cada solicitud personalmente y le escribiremos en las próximas 24 horas.</p>
  </div>

  <div class="contact-alt">O escríbanos directamente a <a href="mailto:jorge@sintelo.com">jorge@sintelo.com</a></div>

  <script>
    document.getElementById('contact-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      btn.textContent = 'Enviando...';
      btn.disabled = true;
      const data = new FormData(this);
      const response = await fetch('https://formspree.io/f/mreokgle', {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      });
      if (response.ok) {
        document.getElementById('contact-form').style.display = 'none';
