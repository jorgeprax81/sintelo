---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getPool } from '../lib/db';
import { buildValueBridge, calcLevers, calcROIC, type BalanceRow, type IncomeRow } from '../lib/roic-engine';

export const prerender = false;

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);

const pool = getPool('bigretailer');

const [isRes, bsRes, cfRes] = await Promise.all([
  pool.query(`SELECT * FROM clientes.income_statement WHERE empresa_id = 1 ORDER BY periodo`),
  pool.query(`SELECT * FROM clientes.balance_sheet WHERE empresa_id = 1 ORDER BY periodo`),
  pool.query(`SELECT * FROM clientes.cash_flow WHERE empresa_id = 1 ORDER BY periodo`),
]);

const is = isRes.rows;
const bs = bsRes.rows;
const cf = cfRes.rows;

const capexByPeriodo = new Map<string, number>(
  cf.map((row) => [String(row.periodo), Number(row.capex || 0)])
);

const incomeRows: IncomeRow[] = is.map((row) => ({
  periodo: String(row.periodo),
  revenue: row.revenue,
  sga: row.sga,
  ebit: row.ebit,
  impuestos: row.impuestos,
  ebt: row.ebt,
  capex: capexByPeriodo.get(String(row.periodo)) ?? 0
}));

const balanceRows: BalanceRow[] = bs.map((row) => ({
  periodo: String(row.periodo),
  ppe: row.ppe,
  cuentas_por_cobrar: row.cuentas_por_cobrar,
  inventario: row.inventario,
  cuentas_por_pagar: row.cuentas_por_pagar
}));

const preferredPeriod = 'Year 7';
const actualIncome = incomeRows.find((row) => row.periodo === preferredPeriod) ?? incomeRows[incomeRows.length - 1];
const actualBalanceRaw = balanceRows.find((row) => row.periodo === actualIncome.periodo) ?? balanceRows[balanceRows.length - 1];

const historicalInventories = balanceRows
  .filter((row) => row.periodo !== actualBalanceRaw.periodo)
  .map((row) => Number(row.inventario || 0));

const inventarioPromedioHistorico = historicalInventories.length > 0
  ? historicalInventories.reduce((sum, value) => sum + value, 0) / historicalInventories.length
  : Number(actualBalanceRaw.inventario || 0);

const actualBalance: BalanceRow = {
  ...actualBalanceRaw,
  inventario_promedio_historico: inventarioPromedioHistorico
};

const actualIndex = incomeRows.findIndex((row) => row.periodo === actualIncome.periodo);
const rowsForEngine = actualIndex >= 0 ? incomeRows.slice(0, actualIndex + 1) : incomeRows;
const leversEngine = calcLevers(rowsForEngine, actualBalance, cf);
const bridge = buildValueBridge(actualIncome, actualBalance, leversEngine);

const leverRoiPp = bridge.levers.map((lever) => lever.delta_pp);
const leverWidths = bridge.levers.map((lever) => {
  const maxImpact = Math.max(...bridge.levers.map((item) => item.impacto), 1);
  return `${Math.round((lever.impacto / maxImpact) * 100)}%`;
});

// Hallazgos derivados desde data — Big Retailer Inc.
const firstIncome = incomeRows[0];
const firstBalance = balanceRows[0];
const yearsSpan = incomeRows.length - 1;
const roicInicial = Number((calcROIC(firstIncome, firstBalance) * 100).toFixed(1));
const roicActual = bridge.roic_actual;
const sgaGrowth = Number(((Math.abs(Number(actualIncome.sga)) / Math.abs(Number(firstIncome.sga)) - 1) * 100).toFixed(0));
const revenueGrowth = Number(((Number(actualIncome.revenue) / Number(firstIncome.revenue) - 1) * 100).toFixed(0));
const inventarioActual = Number(actualBalanceRaw.inventario);
const inventarioDelta = Math.round((inventarioActual - inventarioPromedioHistorico) / 1000);
const inventarioPromedio = Math.round(inventarioPromedioHistorico / 1000);
const inventarioActualB = Math.round(inventarioActual / 1000);

function formatDate(date: Date) {
  return date.toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Layout>

<!-- HERO -->
<section class="hero">
  <div class="eyebrow">Capital Allocation Advisory · Tampico, México</div>
  <h1>Encontramos el valor <em>oculto</em><br>en su empresa.</h1>
  <p class="hero-sub">La mayoría de los dueños de empresas industriales conocen sus ventas y su EBITDA. Pocos saben cuánto capital tienen invertido — y qué retorno genera ese capital.</p>
  <div class="hero-ctas">
    <a href="#contacto" class="btn-primary">Solicitar diagnóstico</a>
    <a href="#metodologia" class="btn-secondary">Ver cómo funciona</a>
  </div>
</section>

<!-- NUMBER STRIP -->
<div class="number-strip">
  <div class="number-item">
    <div class="number-val">+6pp</div>
    <div class="number-label">mejora de margen EBITDA</div>
  </div>
  <div class="number-item">
    <div class="number-val">40%</div>
    <div class="number-label">reducción de working capital</div>
  </div>
  <div class="number-item">
    <div class="number-val">+10pp</div>
    <div class="number-label">incremento de ROIC</div>
  </div>
</div>

<!-- EL PROBLEMA -->
<section id="problema" class="section">
  <div class="label">El problema</div>
  <h2>¿Cuánto vale realmente su empresa<br>— y qué la está frenando?</h2>
  <p class="section-body">La mayoría de los dueños conocen sus ventas y su EBITDA. Pocos saben cuánto capital tienen invertido, qué retorno genera ese capital — y dónde están perdiendo valor cada día.</p>
  <div class="problema-grid">
    <div class="pain">
      <div class="pain-title">Capital atrapado en operaciones</div>
      <p class="pain-text">Inventario excesivo, clientes que pagan tarde, activos subutilizados. El dinero está en el negocio pero no trabaja.</p>
    </div>
    <div class="pain">
      <div class="pain-title">Margen que se escapa sin que nadie lo vea</div>
      <p class="pain-text">Productos que se venden pero no generan utilidad real. Costos de procurement sin negociación. Overhead que creció con los años.</p>
    </div>
    <div class="pain">
      <div class="pain-title">Decisiones de inversión sin criterio de retorno</div>
      <p class="pain-text">Capex basado en intuición. Sin un ROIC mínimo requerido. Sin saber si el siguiente peso invertido genera valor o lo destruye.</p>
    </div>
    <div class="pain pain-accent">
      <div class="pain-title">Estos no son problemas de gestión.</div>
      <p class="pain-text">Son problemas de información y de claridad económica.</p>
    </div>
  </div>
</section>

<!-- TESIS ROIC -->
<section class="section">
  <div class="label">Nuestra tesis</div>
  <h2>El ROIC es el número más importante<br>de su empresa.</h2>
  <p class="section-body">El retorno sobre capital invertido se mueve en dos palancas. Cada decisión operativa mueve una de ellas. Nuestro trabajo es hacerlo visible — y ejecutable.</p>
  <div class="roic-formula">
    <span class="roic-acronym">ROIC</span>
    <span class="roic-eq">=</span>
    <div class="roic-fraction">
      <div class="roic-num">NOPAT (utilidad operativa neta)</div>
      <div class="roic-line"></div>
      <div class="roic-den">Capital Invertido (activos operativos)</div>
    </div>
  </div>
  <div class="roic-grid">
    <div class="palanca">
      <div class="palanca-label">Palanca A</div>
      <div class="palanca-title">Margen operativo</div>
      <div class="palanca-items">Pricing · Costos · Mezcla de productos</div>
      <div class="palanca-arrow">→ Mueve el NOPAT</div>
    </div>
    <div class="palanca">
      <div class="palanca-label">Palanca B</div>
      <div class="palanca-title">Rotación de capital</div>
      <div class="palanca-items">Working capital · Activos · Capex</div>
      <div class="palanca-arrow">→ Mueve el capital invertido</div>
    </div>
  </div>
</section>

<!-- METODOLOGÍA -->
<section id="metodologia" class="section">
  <div class="label">Lo que hace Sintelo</div>
  <h2>Una metodología. Tres formas de trabajar juntos.</h2>

  <!-- CADENA SECUENCIAL -->
  <div class="cadena">

    <!-- Fase 1 -->
    <div class="cadena-bloque">
      <div class="cadena-num-tag">Fase 1</div>
      <div class="cadena-card">
        <div class="cadena-title">Diagnóstico Completo</div>
        <div class="cadena-time">2–6 semanas · precio fijo</div>
        <ul class="fase-list">
          <li>Cálculo de ROIC actual y descomposición por palanca</li>
          <li>Escaneo completo de la cadena de valor</li>
          <li>Benchmarking vs. sector</li>
          <li>Heatmap de levers cuantificados en pesos</li>
          <li>ROIC potencial y roadmap de iniciativas</li>
        </ul>
      </div>
    </div>

    <!-- Flecha -->
    <div class="cadena-arrow" aria-hidden="true">→</div>

    <!-- Fase 2 -->
    <div class="cadena-bloque cadena-bloque-wide">
      <div class="cadena-num-tag">Fase 2</div>
      <div class="cadena-card cadena-card-split">
        <div class="cadena-title">Implementación</div>
        <div class="cadena-time">Con el diagnóstico en mano — elija su track</div>
        <div class="tracks">
          <div class="track track-a">
            <div class="track-label">Track A</div>
            <div class="track-title">Implementación Acelerada</div>
            <div class="track-price">$25–35K / mes</div>
            <ul class="fase-list">
              <li>Ejecución semanal por olas</li>
              <li>Frameworks de captura de valor</li>
              <li>Dashboard mensual de ROIC</li>
              <li>Capacidades internas instaladas</li>
            </ul>
          </div>
          <div class="track-divider" aria-hidden="true">o</div>
          <div class="track track-b">
            <div class="track-label">Track B</div>
            <div class="track-title">Monitoreo Mensual</div>
            <div class="track-price">$12–15K / mes</div>
            <ul class="fase-list">
              <li>Dashboard de ROIC actualizado</li>
              <li>Informe mensual de una página</li>
              <li>Revisión mensual con dirección</li>
              <li>Disciplina de capital a largo plazo</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- SEPARADOR -->
  <div class="cadena-separador">
    <div class="cadena-sep-line"></div>
    <div class="cadena-sep-texto">Producto independiente</div>
    <div class="cadena-sep-line"></div>
  </div>

  <!-- DUE DILIGENCE -->
  <div class="dd-card">
    <div class="dd-encabezado">
      <div class="dd-titulo">Due Diligence Operacional</div>
      <div class="dd-tag">Para compradores estratégicos · family offices · private equity</div>
    </div>
    <p class="dd-desc">Los mismos modelos del diagnóstico aplicados a una empresa que usted quiere adquirir. ROIC histórico real, capital de trabajo verdadero y potencial de mejora post-adquisición — antes de cerrar el trato.</p>
  </div>

</section>

<!-- 10 LEVERS -->
<section class="section">
  <div class="label">La metodología</div>
  <h2>Analizamos la cadena de valor completa.</h2>
  <p class="section-body">El diagnóstico define cuáles de los 10 levers tienen mayor impacto en su empresa específica.</p>
  <div class="levers-grid">
    <div class="lever-group">
      <div class="lever-group-title">Revenue improvement</div>
      <div class="lever-item">Pricing optimization</div>
      <div class="lever-item">Sales enhancement</div>
    </div>
    <div class="lever-group">
      <div class="lever-group-title">Reducción de costos</div>
      <div class="lever-item">Procurement</div>
      <div class="lever-item">Producción</div>
      <div class="lever-item">Distribución</div>
      <div class="lever-item">Postventa</div>
      <div class="lever-item">Overhead</div>
      <div class="lever-item">IT</div>
      <div class="lever-item">Complejidad de producto</div>
      <div class="lever-item">Costos de producto</div>
    </div>
    <div class="lever-group">
      <div class="lever-group-title">Capital</div>
      <div class="lever-item">Working capital</div>
      <div class="lever-item">Optimización de capex</div>
    </div>
  </div>
</section>

<!-- RESULTADOS -->
<section id="resultados" class="section">
  <div class="label">Resultados típicos</div>
  <h2>En empresas industriales medianas.</h2>
  <p class="section-body">Rangos basados en programas de performance improvement en manufactura, alimentos y distribución.</p>
  <div class="resultados-nums">
    <div class="resultado-num">
      <div class="resultado-val">+3–6pp</div>
      <div class="resultado-label">mejora de margen EBITDA</div>
    </div>
    <div class="resultado-num">
      <div class="resultado-val">20–40%</div>
      <div class="resultado-label">reducción de working capital</div>
    </div>
    <div class="resultado-num">
      <div class="resultado-val">+4–10pp</div>
      <div class="resultado-label">incremento de ROIC</div>
    </div>
  </div>
  <div class="resultados-ejemplos">
    <div class="ejemplo">Una empresa con $100M en ventas y 8% de EBITDA que mejora 4 puntos genera <strong>$4M anuales adicionales en flujo</strong> — sin tocar las ventas.</div>
    <div class="ejemplo">Una reducción de 30% en working capital <strong>libera capital que puede reinvertirse o distribuirse hoy.</strong></div>
    <div class="ejemplo">El programa se paga solo — <strong>generalmente en el primer trimestre de implementación.</strong></div>
  </div>
</section>

<!-- POR QUÉ AHORA -->
<section class="section">
  <div class="label">El momento importa</div>
  <h2>¿Por qué hacer esto ahora?</h2>
  <div class="ahora-grid">
    <div class="ahora-item">
      <div class="ahora-num">01</div>
      <div class="ahora-title">El costo del capital subió y no bajará pronto</div>
      <p class="ahora-text">Con tasas altas, tener capital atrapado en inventario o cuentas por cobrar tiene un costo real y creciente. Cada día de retraso en liberarlo tiene precio.</p>
    </div>
    <div class="ahora-item">
      <div class="ahora-num">02</div>
      <div class="ahora-title">Sus competidores ya están optimizando</div>
      <p class="ahora-text">Las empresas que mejoran su ROIC primero consolidan ventajas de costo y escala. Las que esperan se encuentran compitiendo con estructuras más eficientes.</p>
    </div>
    <div class="ahora-item">
      <div class="ahora-num">03</div>
      <div class="ahora-title">El diagnóstico es el primer paso, no el compromiso</div>
      <p class="ahora-text">No tiene que comprometerse a un programa de 24 meses. El diagnóstico es independiente y ya tiene valor por sí mismo como herramienta de decisión.</p>
    </div>
  </div>
</section>

<!-- POR QUÉ SINTELO -->
<section id="por-que-sintelo" class="section">
  <div class="label">Por qué Sintelo</div>
  <h2>Lo que nos diferencia de una<br>consultoría tradicional.</h2>
  <div class="diferenciadores-grid">
    <div class="diferenciador">
      <div class="dif-title">Lente de ROIC total — no ROI por proyecto</div>
      <p class="dif-text">Evaluamos cada iniciativa en términos de su impacto en el ROIC total de la empresa. No vendemos ahorros aislados por área.</p>
    </div>
    <div class="diferenciador">
      <div class="dif-title">Claridad antes del compromiso</div>
      <p class="dif-text">El diagnóstico le da un número: ROIC actual y ROIC potencial. Usted decide si quiere ejecutar. Sin contratos de implementación por adelantado.</p>
    </div>
    <div class="diferenciador">
      <div class="dif-title">Diagnóstico en semanas, no en meses</div>
      <p class="dif-text">Metodología analítica potenciada por IA. Entregamos el diagnóstico inicial en 2–6 semanas con datos concretos.</p>
    </div>
    <div class="diferenciador">
      <div class="dif-title">Socio de largo plazo, no consultor de paso</div>
      <p class="dif-text">Nuestro modelo está diseñado para acompañar la implementación y monitorear el ROIC mes a mes — no entregar un reporte y desaparecer.</p>
    </div>
  </div>
</section>

<!-- WATERFALL -->
<section class="section">
  <div class="label">Waterfall de valor · ROIC actual → ROIC potencial</div>
  <h2>Así se ve el diagnóstico en números.</h2>
  <p class="section-body" style="margin-bottom:2rem">Así se ve un diagnóstico Sintelo en acción. Cada barra muestra cuánto sube el ROIC al activar una palanca específica. La barra azul es el punto de partida. Las verdes son las palancas con mayor impacto cuantificado. La barra final es el ROIC potencial — lo que la empresa puede generar con el capital que ya tiene.</p>
  <div style="position:relative;height:320px;margin-bottom:1rem;">
    <canvas id="wfChart" role="img" aria-label={`Waterfall ROIC de ${bridge.roic_actual.toFixed(1)}% a ${bridge.roic_potencial.toFixed(1)}% via tres levers`}>
      ROIC actual {bridge.roic_actual.toFixed(1)}%, {bridge.levers[0]?.nombre} +{leverRoiPp[0]?.toFixed(1)}pp, {bridge.levers[1]?.nombre} +{leverRoiPp[1]?.toFixed(1)}pp, {bridge.levers[2]?.nombre} +{leverRoiPp[2]?.toFixed(1)}pp, ROIC potencial {bridge.roic_potencial.toFixed(1)}%
    </canvas>
  </div>
  <div class="wf-legend">
    <span class="leg-item"><span class="leg-dot" style="background:#4A8FD4"></span>Punto de partida</span>
    <span class="leg-item"><span class="leg-dot" style="background:#4A9A7A"></span>Valor capturado por lever</span>
  </div>
  <p class="wf-note" style="margin-top:1.25rem;font-size:13px;color:var(--dim);font-style:italic;line-height:1.7;max-width:720px">Cómo leerlo: cada barra verde representa una palanca independiente cuantificada con datos reales. La altura indica cuántos puntos de ROIC suma esa palanca al activarse. El ROIC potencial es la suma de las tres. Cifras en USD.</p>
</section>

<!-- LEVERS -->
<section class="section">
  <div class="label">Levers prioritarios · impacto cuantificado</div>
  <h2>Tres palancas. Impacto cuantificado.</h2>
  <div class="levers">
    <div class="lever-header">
      <span>Lever</span>
      <span>Impacto relativo</span>
      <span>Valor capturado</span>
      <span>ROIC</span>
    </div>
    {bridge.levers.map((lever, index) => (
      <div class="lever">
        <div class="lname">{String(index + 1).padStart(2, '0')} · {lever.nombre}</div>
        <div class="lbar-wrap"><div class="lbar" style={`width:${leverWidths[index]};background:${lever.color}`}></div></div>
        <div class="lval">+${(lever.impacto / 1000).toFixed(1)}B USD{lever.frecuencia === 'anual' ? '/año' : ''}</div>
        <div class="lroic">+{leverRoiPp[index].toFixed(1)}pp</div>
      </div>
    ))}
  </div>
</section>

<!-- BUSINESS CASE -->
<section class="section">
  <div class="label">Business case total</div>
  <h2>El valor capturable en tres años.</h2>
  <div class="bc-grid">
    <div class="bc">
      <div class="bc-val">${(bridge.total_valor / 1000).toFixed(1)}B USD</div>
      <div class="bc-label">Valor total capturado</div>
      <div class="bc-sub">En 3 años de implementación</div>
    </div>
    <div class="bc">
      <div class="bc-val">{bridge.roic_potencial.toFixed(1)}%</div>
      <div class="bc-label">ROIC potencial</div>
      <div class="bc-sub">vs {bridge.roic_actual.toFixed(1)}% actual</div>
    </div>
    <div class="bc">
      <div class="bc-val">+{bridge.delta_pp.toFixed(1)}pp</div>
      <div class="bc-label">Mejora de ROIC</div>
      <div class="bc-sub">En 3 años</div>
    </div>
  </div>
  <p class="section-body" style="margin-top:2rem;font-style:italic">La metodología es la misma para empresas de cualquier tamaño. Los números escalan a la realidad de cada negocio — en pesos, no en dólares.</p>
</section>

<!-- DEMO -->
<section id="demo" class="section">
  <div class="label">En acción</div>
  <h2>Dos diagnósticos reales. Dos tipos de empresa.</h2>
  <p class="section-body">Cada demo está conectado en tiempo real a su base de datos — los números que ve se calculan en el momento, exactamente como lo haríamos con sus datos.</p>
  <p class="section-body" style="margin-top:1rem"><strong style="color:#C8C3B8">Big Retailer Inc.</strong> — retailer global con estados financieros completos auditados. Este es el diagnóstico para empresas que tienen P&amp;L, Balance y Flujo de Caja estructurados. Calculamos el ROIC real histórico y construimos el Potential Report con impacto cuantificado.</p>
  <p class="section-body" style="margin-top:1rem"><strong style="color:#C8C3B8">AdventureWorks Inc.</strong> — manufacturera con datos operativos en su ERP. Este es el diagnóstico para empresas que no tienen estados financieros formales pero sí datos de ventas, inventario y costos. Identificamos los levers operativos con mayor impacto.</p>
  <p class="section-body" style="margin-top:1rem">Su empresa cae en uno de estos dos casos. El proceso es el mismo.</p>
  <div class="demo-card" style="margin-bottom: 1.5rem">
    <div class="demo-left">
      <div class="demo-tag">Diagnóstico con estados financieros</div>
      <div class="demo-company">Big Retailer Inc.</div>
      <p class="demo-desc">Retailer global · $559B en revenue · 8 años de estados financieros completos</p>
      <div class="demo-hallazgos">
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">01</div><div class="demo-hallazgo-text">ROIC cayó de {roicInicial}% a {roicActual}% en {yearsSpan} años — capital creciendo más que retornos</div></div>
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">02</div><div class="demo-hallazgo-text">SG&amp;A creció {sgaGrowth}% mientras revenue creció {revenueGrowth}% — overhead sin control</div></div>
        <div class="demo-hallazgo"><div class="demo-hallazgo-num">03</div><div class="demo-hallazgo-text">Inventario creció ${inventarioDelta}B sobre el promedio histórico (${inventarioActualB}B vs ${inventarioPromedio}B)</div></div>
      </div>
    </div>
    <div class="demo-right">
      <div class="demo-impacto-label">Valor capturable estimado</div>
      <div class="demo-impacto-val">${(bridge.total_valor / 1000).toFixed(1)}B</div>
      <div class="demo-impacto-sub">en tres iniciativas prioritarias</div>
      <div class="demo-items">
        <div class="demo-item"><div class="demo-item-desc">{bridge.levers[0].nombre}</div><div class="demo-item-val">~${(bridge.levers[0].impacto / 1000).toFixed(1)}B</div></div>
        <div class="demo-item"><div class="demo-item-desc">{bridge.levers[1].nombre}</div><div class="demo-item-val">~${(bridge.levers[1].impacto / 1000).toFixed(1)}B</div></div>
        <div class="demo-item"><div class="demo-item-desc">{bridge.levers[2].nombre}</div><div class="demo-item-val">~${(bridge.levers[2].impacto / 1000).toFixed(1)}B</div></div>
      </div>
      <a href="/demo/big-retailer" class="btn-demo">Ver diagnóstico completo →</a>
    </div>
  </div>
