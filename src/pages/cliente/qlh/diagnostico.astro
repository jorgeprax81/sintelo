---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Diagnóstico ROIC · Quesos La Hacienda — Sintelo</title>
<meta name="description" content="Scorecard del árbol ROIC y razones financieras, ejercicios 2023–2025.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #FAF7F2;
    --surface: #FFFFFF;
    --ink: #1A1815;
    --ink-soft: #4A453E;
    --muted: #8A8378;
    --rule: #E5DFD5;
    --rule-soft: #EFEAE0;
    --brand: #2B2824;
    --pos: #2F4A2F;
    --pos-bg: #EEF1E8;
    --neg: #7A2420;
    --neg-bg: #F5E8E5;
    --accent: #8B6914;
    --font-display: "Fraunces", Georgia, serif;
    --font-body: "IBM Plex Sans", -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: "IBM Plex Mono", ui-monospace, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.55;
    padding: 48px 24px 72px;
  }
  .document {
    max-width: 920px;
    margin: 0 auto;
    background: var(--surface);
    border: 0.5px solid var(--rule);
    padding: 56px 64px 48px;
  }
  .masthead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--ink);
    margin-bottom: 28px;
  }
  .masthead-brand {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }
  .masthead-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.02em;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  h1 {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-variation-settings: "opsz" 96;
    font-weight: 500;
    font-size: 44px;
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 14px;
    color: var(--ink);
  }
  h1 em { font-style: italic; font-weight: 400; color: var(--ink-soft); }
  .lede {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 14;
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 640px;
    margin-bottom: 40px;
  }
  .divider {
    height: 1px;
    background: var(--rule);
    margin: 40px 0 32px;
    position: relative;
  }
  .divider::after {
    content: "§";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--surface);
    color: var(--muted);
    padding: 0 14px;
    font-family: var(--font-display);
    font-size: 16px;
  }
  .section-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 22px; }
  .section-num {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 72;
    font-size: 32px;
    font-weight: 400;
    font-style: italic;
    color: var(--accent);
    line-height: 1;
  }
  .section-title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 36;
    font-size: 22px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
  }
  .roic-tree { margin-bottom: 44px; }
  .roic-formula {
    display: grid;
    grid-template-columns: 1fr 40px 1fr 40px 1fr;
    gap: 0;
    align-items: stretch;
  }
  .roic-node { padding: 20px 18px; border: 0.5px solid var(--rule); background: var(--surface); position: relative; }
  .roic-node--result { background: var(--neg-bg); border-color: var(--neg); }
  .roic-op {
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-variation-settings: "opsz" 72;
    font-size: 28px;
    font-weight: 400;
    color: var(--muted);
  }
  .roic-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .roic-node--result .roic-label { color: var(--neg); }
  .roic-value {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 96;
    font-size: 38px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    margin-bottom: 8px;
  }
  .roic-node--result .roic-value { color: var(--neg); }
  .roic-trail { font-family: var(--font-mono); font-size: 11px; color: var(--muted); margin-bottom: 10px; letter-spacing: -0.01em; }
  .roic-delta { display: inline-flex; align-items: center; gap: 4px; font-family: var(--font-mono); font-size: 12px; font-weight: 500; color: var(--neg); letter-spacing: -0.01em; }
  .roic-wacc { display: flex; justify-content: space-between; align-items: center; margin-top: 20px; padding-top: 18px; border-top: 0.5px solid var(--rule); font-size: 13px; }
  .roic-wacc-left { color: var(--ink-soft); }
  .roic-wacc-left strong { font-weight: 500; color: var(--ink); font-family: var(--font-mono); margin-left: 6px; }
  .roic-wacc-right { font-family: var(--font-body); font-weight: 500; color: var(--neg); font-size: 13px; }
  .roic-wacc-right .val { font-family: var(--font-mono); margin: 0 4px; }
  .group { margin-bottom: 32px; }
  .group-head {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 24;
    font-size: 15px;
    font-weight: 500;
    font-style: italic;
    color: var(--ink);
    padding-bottom: 8px;
    border-bottom: 0.5px solid var(--ink);
    margin-bottom: 2px;
  }
  .row {
    display: grid;
    grid-template-columns: minmax(0, 2.4fr) repeat(3, minmax(0, 0.9fr)) minmax(0, 1.3fr);
    gap: 12px;
    padding: 11px 0;
    border-bottom: 0.5px solid var(--rule-soft);
    align-items: baseline;
  }
  .row-header {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 10px 0 6px;
    border-bottom: 0.5px solid var(--rule);
  }
  .row-header .col-val, .row-header .col-delta { text-align: right; }
  .row-name { font-size: 14px; color: var(--ink); }
  .col-val { font-family: var(--font-mono); font-size: 13px; text-align: right; color: var(--ink-soft); font-variant-numeric: tabular-nums; }
  .col-val.latest { color: var(--ink); font-weight: 500; }
  .col-delta { text-align: right; font-family: var(--font-mono); font-size: 12px; font-weight: 500; font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }
  .col-delta.pos { color: var(--pos); }
  .col-delta.neg { color: var(--neg); }
  .col-delta .arrow { display: inline-block; margin-right: 3px; }
  footer {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--ink);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
  }
  .colophon { font-family: var(--font-mono); font-size: 11px; color: var(--muted); line-height: 1.6; flex: 1; }
  .confidential { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--neg); padding: 4px 10px; border: 0.5px solid var(--neg); white-space: nowrap; }
  .fade-in { opacity: 0; transform: translateY(8px); animation: rise 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
  @keyframes rise { to { opacity: 1; transform: translateY(0); } }
  @media (max-width: 720px) {
    body { padding: 24px 12px; }
    .document { padding: 32px 24px; }
    h1 { font-size: 32px; }
    .lede { font-size: 15px; }
    .roic-formula { grid-template-columns: 1fr; gap: 12px; }
    .roic-op { font-size: 20px; padding: 4px 0; }
    .roic-value { font-size: 30px; }
    .row { grid-template-columns: minmax(0, 2fr) repeat(3, minmax(0, 0.8fr)) minmax(0, 1.4fr); gap: 6px; font-size: 12px; }
    .row-name { font-size: 13px; }
    .col-val { font-size: 11px; }
    .col-delta { font-size: 11px; }
    footer { flex-direction: column-reverse; gap: 20px; }
    .masthead { flex-direction: column; gap: 4px; align-items: flex-start; }
  }
</style>
</head>
<body>
<article class="document">

<div class="masthead">
  <div class="masthead-brand">Sintelo · Private Investment</div>
  <div class="masthead-meta">Fase 1 · Abril 2026</div>
</div>

<div class="eyebrow fade-in" style="animation-delay: 0.05s">Diagnóstico financiero</div>
<h1 class="fade-in" style="animation-delay: 0.1s">
  Quesos La Hacienda<br>
  <em>Árbol ROIC y razones financieras</em>
</h1>
<p class="lede fade-in" style="animation-delay: 0.2s">
  Ejercicios 2023–2025. Del pico operativo (ROIC 18.8%) a la destrucción sostenida de valor frente a un costo de capital de 15%. El deterioro combina compresión de márgenes y caída en la rotación del capital invertido.
</p>

<section class="roic-tree fade-in" style="animation-delay: 0.3s">
  <div class="section-head">
    <div class="section-num">I.</div>
    <div class="section-title">Árbol ROIC — descomposición DuPont</div>
  </div>
  <div class="roic-formula">
    <div class="roic-node">
      <div class="roic-label">Margen NOPAT</div>
      <div class="roic-value">0.3%</div>
      <div class="roic-trail">2023: 9.7% → 2024: 0.8%</div>
      <div class="roic-delta">↓&nbsp;−9.4 pp</div>
    </div>
    <div class="roic-op">×</div>
    <div class="roic-node">
      <div class="roic-label">Rotación de capital</div>
      <div class="roic-value">1.56x</div>
      <div class="roic-trail">2023: 1.95x → 2024: 1.68x</div>
      <div class="roic-delta">↓&nbsp;−0.39x (−20%)</div>
    </div>
    <div class="roic-op">=</div>
    <div class="roic-node roic-node--result">
      <div class="roic-label">ROIC</div>
      <div class="roic-value">0.4%</div>
      <div class="roic-trail">2023: 18.8% → 2024: 1.4%</div>
      <div class="roic-delta">↓&nbsp;−18.4 pp</div>
    </div>
  </div>
  <div class="roic-wacc">
    <div class="roic-wacc-left">WACC de referencia<strong>15.0%</strong></div>
    <div class="roic-wacc-right">
      Spread ROIC − WACC<span class="val">−14.6 pp</span>· destruye valor
    </div>
  </div>
</section>

<div class="divider"></div>

<section class="scorecard fade-in" style="animation-delay: 0.4s">
  <div class="section-head">
    <div class="section-num">II.</div>
    <div class="section-title">Razones financieras — evolución 2023 → 2025</div>
  </div>
  <div id="scorecard-root"></div>
</section>

<footer>
  <div class="colophon">
    Fuente: P&L Estado de Resultados Gerencial · Balance CONTPAQ<br>
    Revisión Sintelo · Validado por Contraloría · Abril 2026<br>
    Deltas 2023→2025 en puntos porcentuales (pp) para ratios, CAGR para flujos.
  </div>
  <div class="confidential">Confidencial</div>
</footer>

</article>

<script>
const RATIOS = [
  {
    group: "Rentabilidad",
    items: [
      { name: "Margen bruto",            v: [42.9, 40.3, 39.1], unit: "pct", better: "up" },
      { name: "Margen EBITDA",           v: [15.0,  2.9,  1.9], unit: "pct", better: "up" },
      { name: "Margen EBIT",             v: [13.8,  1.2,  0.4], unit: "pct", better: "up" },
      { name: "Margen NOPAT",            v: [ 9.7,  0.8,  0.3], unit: "pct", better: "up" },
      { name: "Margen neto",             v: [11.0, -1.2, -1.5], unit: "pct", better: "up" },
      { name: "ROIC",                    v: [18.8,  1.4,  0.4], unit: "pct", better: "up" },
      { name: "Spread ROIC − WACC",      v: [ 3.8,-13.6,-14.6], unit: "pp_abs", better: "up" },
    ]
  },
  {
    group: "Estructura de costos",
    items: [
      { name: "Costo de producción / Ventas",       v: [57.1, 59.7, 60.9], unit: "pct", better: "down" },
      { name: "Gastos de venta / Ventas",           v: [10.5, 11.7, 13.3], unit: "pct", better: "down" },
      { name: "Gastos de administración / Ventas",  v: [ 3.5,  6.2,  5.6], unit: "pct", better: "down" },
      { name: "Gastos de operación / Ventas",       v: [10.9, 13.3, 14.4], unit: "pct", better: "down" },
      { name: "Mermas / Ventas",                    v: [ 1.9,  3.5,  3.3], unit: "pct", better: "down" },
      { name: "Degustaciones / Ventas",             v: [ 1.1,  0.8,  0.7], unit: "pct", better: "down" },
      { name: "Gastos financieros / Ventas",        v: [ 2.8,  2.4,  1.9], unit: "pct", better: "down" },
    ]
  },
  {
    group: "Eficiencia y capital de trabajo",
    items: [
      { name: "Rotación de capital invertido", v: [1.95, 1.68, 1.56], unit: "turns", better: "up" },
      { name: "Rotación de PP&E neto",         v: [2.61, 2.32, 2.22], unit: "turns", better: "up" },
      { name: "Rotación de inventarios",       v: [50.2, 27.2, 29.7], unit: "turns", better: "up" },
      { name: "Días de cobro (DSO)",           v: [54.6, 59.8, 70.9], unit: "days",  better: "down" },
      { name: "Días de inventario (DIO)",      v: [ 7.3, 13.4, 12.3], unit: "days",  better: "down" },
    ]
  },
  {
    group: "Ingresos",
    items: [
      { name: "Ventas netas (MXN millones)",        v: [110.8, 95.7, 89.0], unit: "money_m", better: "up" },
      { name: "Crecimiento anual / CAGR 2023–2025", v: [null, -13.6, -10.3], unit: "pct", better: "up" },
    ]
  },
];

function formatValue(val, unit) {
  if (val === null || val === undefined) return "—";
  switch (unit) {
    case "pct":
    case "pp_abs":   return val.toFixed(1) + "%";
    case "turns":    return val.toFixed(2) + "x";
    case "days":     return val.toFixed(1) + " d";
    case "money_m":  return "$" + val.toFixed(1) + "M";
    default:         return String(val);
  }
}

function computeDelta(item) {
  const first = item.v[0], last = item.v[item.v.length - 1];
  if (first === null) {
    return { text: "CAGR " + last.toFixed(1) + " pp", d: last, good: item.better === "up" ? last >= 0 : last <= 0 };
  }
  const d = last - first;
  let text;
  if (item.unit === "turns") {
    const pct = first !== 0 ? (d / first) * 100 : 0;
    const sign = d >= 0 ? "+" : "";
    text = sign + d.toFixed(2) + "x (" + sign + pct.toFixed(0) + "%)";
  } else if (item.unit === "days") {
    const sign = d >= 0 ? "+" : "";
    text = sign + d.toFixed(1) + " d";
  } else if (item.unit === "money_m") {
    const pct = first !== 0 ? (d / first) * 100 : 0;
    const sign = d >= 0 ? "+" : "";
    text = sign + d.toFixed(1) + "M (" + sign + pct.toFixed(1) + "%)";
  } else {
    const sign = d >= 0 ? "+" : "";
    text = sign + d.toFixed(1) + " pp";
  }
  const good = (item.better === "up" && d >= 0) || (item.better === "down" && d <= 0);
  return { text, d, good };
}

function render() {
  const root = document.getElementById("scorecard-root");
  let html = "";
  for (const section of RATIOS) {
    html += '<div class="group">';
    html += '<div class="group-head">' + section.group + '</div>';
    html += '<div class="row row-header">';
    html += '<div></div>';
    html += '<div class="col-val">2023</div>';
    html += '<div class="col-val">2024</div>';
    html += '<div class="col-val">2025</div>';
    html += '<div class="col-delta">Δ 23 → 25</div>';
    html += '</div>';
    for (const item of section.items) {
      const d = computeDelta(item);
      const arrow = d.d >= 0 ? "↑" : "↓";
      const cls = d.good ? "pos" : "neg";
      html += '<div class="row">';
      html += '<div class="row-name">' + item.name + '</div>';
      html += '<div class="col-val">' + formatValue(item.v[0], item.unit) + '</div>';
      html += '<div class="col-val">' + formatValue(item.v[1], item.unit) + '</div>';
      html += '<div class="col-val latest">' + formatValue(item.v[2], item.unit) + '</div>';
      html += '<div class="col-delta ' + cls + '"><span class="arrow">' + arrow + '</span>' + d.text + '</div>';
      html += '</div>';
    }
    html += '</div>';
  }
  root.innerHTML = html;
}

render();
</script>
</body>
</html>
