---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Sintelo — Capital Allocation Advisory', description = 'Encontramos el valor oculto en su empresa. Diagnóstico de ROIC para empresas industriales en México.' } = Astro.props;
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <meta name="google-site-verification" content="kkpWBEdPj47d84dQci6BzqPw2TPRT4qFkb9fVtZUPeU" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://sintelo.com/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content="https://sintelo.com" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Sintelo" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://sintelo.com/og-image.png" />
</head>
<body>

<nav>
  <a href="/" class="logo">SINTELO</a>
  <div class="nav-links">
    <a href="/#problema">El problema</a>
    <a href="/#servicios">Servicios</a>
    <a href="/#resultados">Resultados</a>
    <a href="/blog">Blog</a>
    <a href="/demo">Demo</a>
    <a href="/#jorge">Jorge Castro</a>
  </div>
  <a href="/#contacto" class="nav-cta">Diagnóstico →</a>
</nav>

<slot />

<Analytics />

<footer>
  <div class="footer-logo">SINTELO</div>
  <div class="footer-copy">© 2025 Sintelo · Capital Allocation Advisory · Tampico, México</div>
</footer>

</body>
</html>

<style>
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 3rem;
  border-bottom: 0.5px solid var(--border);
  position: sticky;
  top: 0;
  background: var(--bg);
  z-index: 100;
}
.logo {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 500;
  letter-spacing: 0.08em;
}
.nav-links {
  display: flex;
  gap: 2rem;
  font-size: 13px;
  font-weight: 300;
  color: var(--muted);
  letter-spacing: 0.04em;
}
.nav-links a:hover { color: var(--accent); }
.nav-cta {
  font-size: 12px;
  border: 0.5px solid var(--accent);
  color: var(--accent);
  padding: 0.5rem 1.25rem;
  letter-spacing: 0.08em;
  font-weight: 400;
  transition: background 0.2s;
}
.nav-cta:hover { background: var(--accent-dim); }
footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 2rem 3rem;
  border-top: 0.5px solid var(--border);
}
.footer-logo {
  font-family: var(--serif);
  font-size: 16px;
  color: var(--faint);
  letter-spacing: 0.08em;
}
.footer-copy { font-size: 12px; color: var(--faint); }
@media (max-width: 768px) {
  nav { padding: 1.25rem 1.5rem; }
  .nav-links { display: none; }
  footer { flex-direction: column; gap: 0.5rem; padding: 1.5rem; text-align: center; }
}
</style>
