---
const company = 'Big Retailer Inc.';
const roicActual = 10.1;
const roicPotencial = 13.5;
const deltaRoic = '+3.4pp ROIC';
const periodo = 'Year 7';

const baseValueM = 0;
const totalBridgeM = 36000;

const levers = [
  {
    key: 'sga-overhead',
    name: 'Reducir SG&A / Overhead',
    palanca: 'A — Margen',
    description: 'SG&A creció 25% en 8 años mientras revenue creció 15%',
    impactM: 11000,
    color: '#7F77DD'
  },
  {
    key: 'roic-capex',
    name: 'Criterio ROIC en capex',
    palanca: 'B — Capital',
    description: '$126B en capex en 4 años sin ROIC mínimo requerido',
    impactM: 8000,
    color: '#85B7EB'
  },
  {
    key: 'inventario',
    name: 'Normalizar inventario',
    palanca: 'B — Capital',
    description: 'Inventario saltó $20B en Year 7 sin crecimiento de revenue',
    impactM: 17000,
    color: '#9FE1CB'
  }
];
---

<section
  class="value-bridge"
  data-current={baseValueM}
  data-potential={totalBridgeM}
>
  <header class="vb-header">
    <div>
      <p class="vb-eyebrow">Value Bridge</p>
      <h3>{company}</h3>
      <p class="vb-sub">Periodo: {periodo} · Business case total: ${(totalBridgeM / 1000).toFixed(1)}B</p>
    </div>
    <div class="vb-metrics">
      <div class="vb-metric">
        <span class="vb-label">ROIC actual</span>
        <strong>{roicActual.toFixed(1)}%</strong>
      </div>
      <div class="vb-metric">
        <span class="vb-label">ROIC potencial</span>
        <strong>{roicPotencial.toFixed(1)}%</strong>
      </div>
      <div class="vb-metric vb-metric-delta">
        <span class="vb-label">Delta ROIC</span>
        <strong>{deltaRoic}</strong>
      </div>
    </div>
  </header>

  <div class="vb-chart">
    <div class="vb-bars" style={`grid-template-columns: repeat(${levers.length + 2}, minmax(120px, 1fr));`}>
      <div
        class="vb-bar-col vb-base"
        data-bar
        data-kind="base"
        data-value={baseValueM}
        data-color="#0F2742"
        data-label="Base"
      >
        <span class="vb-top-label">Base</span>
        <div class="vb-bar"><span class="vb-value"></span></div>
      </div>

      {levers.map((lever) => (
        <div
          class="vb-bar-col vb-lever"
          data-bar
          data-kind="lever"
          data-value={lever.impactM}
          data-color={lever.color}
          data-label={lever.name}
        >
          <span class="vb-top-label">{lever.name}<br />{lever.palanca}</span>
          <div class="vb-bar"><span class="vb-value"></span></div>
        </div>
      ))}

      <div
        class="vb-bar-col vb-final"
        data-bar
        data-kind="final"
        data-value={totalBridgeM}
        data-color="#54B284"
        data-label="Total"
      >
        <span class="vb-top-label">Business case total</span>
        <div class="vb-bar"><span class="vb-value"></span></div>
      </div>
    </div>
  </div>

  <ul class="vb-lever-list">
    {levers.map((lever) => (
      <li class="vb-lever-row">
        <span class="vb-dot" style={`--dot:${lever.color}`}></span>
        <div class="vb-lever-copy">
          <div class="vb-lever-title">{lever.name}</div>
          <div class="vb-lever-desc">{lever.palanca}</div>
          <div class="vb-lever-desc">{lever.description}</div>
        </div>
        <strong class="vb-lever-value">+${(lever.impactM / 1000).toFixed(1)}B</strong>
      </li>
    ))}
  </ul>

  <footer class="vb-total">
    <div class="vb-total-row">
      <span>Total value bridge (business case demo)</span>
      <strong>+${(totalBridgeM / 1000).toFixed(1)}B</strong>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const formatBillions = (valueM) => `$${(valueM / 1000).toFixed(1)}B`;

      document.querySelectorAll('.value-bridge').forEach((bridge) => {
        const current = Number(bridge.dataset.current || 0);
        const potential = Number(bridge.dataset.potential || 0);
        const cols = Array.from(bridge.querySelectorAll('[data-bar]'));

        let running = current;
        const spans = [];

        cols.forEach((col) => {
          const kind = col.dataset.kind;
          const value = Number(col.dataset.value || 0);

          if (kind === 'base') {
            spans.push({ col, start: 0, end: value, value });
            return;
          }

          if (kind === 'lever') {
            const start = running;
            const end = running + value;
            spans.push({ col, start, end, value });
            running = end;
            return;
          }

          spans.push({ col, start: 0, end: value, value });
        });

        const maxValue = Math.max(
          potential,
          running,
          ...spans.map((item) => item.end)
        );

        spans.forEach(({ col, start, end, value }) => {
          const bar = col.querySelector('.vb-bar');
          const valueNode = col.querySelector('.vb-value');
          const color = col.dataset.color || '#7F77DD';
          const heightPct = ((end - start) / maxValue) * 100;
          const bottomPct = (start / maxValue) * 100;

          if (bar) {
            bar.style.height = `${heightPct}%`;
            bar.style.bottom = `${bottomPct}%`;
            bar.style.background = color;
          }

          if (valueNode) {
            const prefix = col.dataset.kind === 'lever' ? '+' : '';
            valueNode.textContent = `${prefix}${formatBillions(value)}`;
          }
        });
      });
    })();
  </script>
</section>

<style>
.value-bridge {
  border: 1px solid var(--border);
  background: var(--bg);
  color: var(--text);
  padding: 2rem;
}

.vb-header {
  display: flex;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 2rem;
  border-bottom: 1px solid var(--border);
  padding-bottom: 1.25rem;
}

.vb-eyebrow {
  margin: 0 0 0.5rem;
  color: var(--dim);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.vb-header h3 {
  margin: 0;
  font-size: 1.6rem;
}

.vb-sub {
  margin: 0.5rem 0 0;
  color: var(--dim);
  font-size: 0.9rem;
}

.vb-metrics {
  display: flex;
  gap: 0.85rem;
  align-items: flex-end;
}

.vb-metric {
  min-width: 9rem;
  border: 1px solid var(--border);
  padding: 0.7rem 0.85rem;
}

.vb-label {
  display: block;
  color: var(--dim);
  font-size: 0.75rem;
  margin-bottom: 0.25rem;
}

.vb-metric strong {
  font-size: 1.1rem;
}

.vb-metric-delta strong {
  color: #54B284;
}

.vb-chart {
  border: 1px solid var(--border);
  padding: 1.1rem;
  overflow-x: auto;
}

.vb-bars {
  display: grid;
  gap: 0.9rem;
  align-items: end;
  min-height: 24rem;
}

.vb-bar-col {
  position: relative;
  min-height: 22rem;
  border: 1px solid var(--border);
  padding: 0.75rem;
}

.vb-top-label {
  display: block;
  font-size: 0.76rem;
  color: var(--dim);
  line-height: 1.35;
  margin-bottom: 0.5rem;
}

.vb-bar {
  position: absolute;
  left: 0.75rem;
  right: 0.75rem;
  bottom: 0;
  min-height: 1.1rem;
  border-radius: 0.15rem;
}

.vb-value {
  position: absolute;
  right: 0.35rem;
  top: 0.35rem;
  color: #0B1217;
  font-size: 0.72rem;
  font-weight: 700;
}

.vb-lever-list {
  margin: 1.35rem 0 0;
  padding: 0;
  list-style: none;
  border: 1px solid var(--border);
}

.vb-lever-row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 0.9rem;
  align-items: center;
  padding: 0.9rem 1rem;
  border-bottom: 1px solid var(--border);
}

.vb-lever-row:last-child {
  border-bottom: 0;
}

.vb-dot {
  width: 0.7rem;
  height: 0.7rem;
  border-radius: 50%;
  background: var(--dot);
}

.vb-lever-title {
  font-size: 0.95rem;
  margin-bottom: 0.2rem;
}

.vb-lever-desc {
  color: var(--dim);
  font-size: 0.82rem;
  line-height: 1.4;
}

.vb-lever-value {
  font-size: 0.9rem;
}

.vb-total {
  margin-top: 1rem;
  border: 1px solid var(--border);
}

.vb-total-row {
  display: flex;
  justify-content: space-between;
  gap: 0.75rem;
  padding: 0.9rem 1rem;
  border-bottom: 1px solid var(--border);
}

.vb-total-row:last-child {
  border-bottom: 0;
}

.vb-total-row span {
  color: var(--dim);
  font-size: 0.86rem;
}

@media (max-width: 900px) {
  .value-bridge {
    padding: 1.25rem;
  }

  .vb-header {
    flex-direction: column;
  }

  .vb-metrics {
    width: 100%;
    flex-wrap: wrap;
  }

  .vb-metric {
    flex: 1 1 9rem;
  }
}
</style>
